{# Token migration: arbitrary values replaced — Phase 1B #}
---
layout: layouts/base.njk
title: Source Documents
description: The primary source record behind Democratic Justice reporting.
permalink: /documents/index.html
ogType: website
---
<section class="page-shell page-shell--bento" data-pagefind-body>
  <header class="page-header">
    <div class="sr-only" aria-hidden="true">
      <span data-pagefind-meta="type">Source document archive</span>
    </div>
    <p class="section-kicker">Source archive</p>
    <h1 class="page-title">Source documents</h1>
    <p class="page-description">The document record behind the reporting. Open the file, inspect the entry, and move back into the archive.</p>
    <div class="mt-4 flex flex-wrap gap-2">
      <a class="button-link-muted" href="/search/">Search archive</a>
      <a class="button-link-muted" href="/archives/">Reporting archive</a>
    </div>
  </header>

  <div class="document-index-grid">
    {% for document in collections.sourceDocument %}
      {% set docRankClass = "math-rank-major" if loop.first else ("math-rank-medium" if loop.index <= 3 else "math-rank-small") %}
      {% set docRank = "major" if loop.first else ("medium" if loop.index <= 3 else "small") %}
      <article class="listing-card document-index-card p-4 md:p-5 {{ docRankClass }}" data-math-rank="{{ docRank }}">
        <div class="grid gap-3 md:grid-cols-[minmax(0,1fr)_auto] md:items-start">
          <div>
            <p class="section-kicker">{{ document.data.obtained | displayDate }}</p>
            <h2 class="mt-2 font-display text-3xl font-semibold tracking-tight text-ink">
              <a class="headline-link" href="{{ document.url }}">{{ document.data.title }}</a>
            </h2>
            <p class="mt-2 max-w-3xl font-serif text-base leading-relaxed text-ink-secondary">{{ document.data.description }}</p>
            <p class="mt-3 font-mono text-2xs uppercase tracking-wide text-ink-muted">{{ document.data.source_method }}</p>
          </div>
          <div class="flex flex-wrap gap-2 md:justify-end">
            <a class="button-link-muted" href="{{ document.url }}">Open record</a>
            <a class="button-link-muted" href="{{ document.data.file }}">Open file</a>
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
</section>
