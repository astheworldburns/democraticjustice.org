---
layout: layouts/base.njk
title: Source Documents
description: The primary source record behind Democratic Justice reporting.
permalink: /documents/index.html
ogType: website
---
<main id="main-content">
  <section aria-labelledby="docs-heading" data-pagefind-body>
    <div class="sr-only" aria-hidden="true">
      <span data-pagefind-meta="type">Source document archive</span>
    </div>
    {% set sectionKicker = "Archive" %}{% set sectionTitle = "Source Documents" %}{% set sectionId = "docs-heading" %}
    {% include "components/section-header.njk" %}
    <div class="mb-6 flex flex-wrap gap-2">
      <a class="button-link-muted" href="/search/">Search archive</a>
      <a class="button-link-muted" href="/archives/">Reporting archive</a>
    </div>
    <div class="bento-grid">
      {% for doc in collections.sourceDocument %}
        {% set docTitle = doc.data.title %}{% set docDescription = doc.data.description %}{% set docUrl = doc.url %}{% set docFile = doc.data.file %}{% set docFileType = doc.data.file_type %}{% set docObtained = doc.data.obtained %}{% set docSourceMethod = doc.data.source_method %}
        <div class="bento-4">{% include "components/document-card.njk" %}</div>
      {% endfor %}
    </div>
  </section>
</main>
