---
layout: layouts/base.njk
title: Source Documents
description: The primary source record behind Democratic Justice reporting.
permalink: /documents/index.html
ogType: website
---
<section class="space-y-8" data-pagefind-body>
  <header class="border-b-2 border-[rgb(var(--rule-strong))] pb-6">
    <div class="sr-only" aria-hidden="true">
      <span data-pagefind-meta="type">Source document archive</span>
    </div>
    <p class="section-kicker">Source archive</p>
    <h1 class="mt-3 font-display text-[clamp(2.7rem,5vw,4.4rem)] font-black tracking-tight text-[rgb(var(--ink))]">
      Source documents
    </h1>
    <p class="mt-4 max-w-3xl font-serif text-lg leading-relaxed text-[rgb(var(--ink-soft))]">
      The document record behind the reporting. Open the source file, inspect the entry, and move back into the archive.
    </p>
    <div class="mt-5 flex flex-wrap gap-3">
      <a class="button-link-muted" href="/search/">Search the archive</a>
      <a class="button-link-muted" href="/archives/">Reporting archive</a>
    </div>
  </header>

  <div class="space-y-4">
    {% for document in collections.sourceDocument %}
      <article class="listing-card p-5 md:p-6">
        <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_auto] md:items-start">
          <div>
            <p class="section-kicker">{{ document.data.obtained | displayDate }}</p>
            <h2 class="mt-2 font-display text-3xl font-black tracking-tight text-[rgb(var(--ink))]">
              <a class="headline-link" href="{{ document.url }}">{{ document.data.title }}</a>
            </h2>
            <p class="mt-3 max-w-3xl font-serif text-base leading-relaxed text-[rgb(var(--ink-soft))]">
              {{ document.data.description }}
            </p>
            <p class="mt-4 font-ui text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--ink-muted))]">
              {{ document.data.source_method }}
            </p>
          </div>
          <div class="flex flex-wrap gap-3 md:justify-end">
            <a class="button-link-muted" href="{{ document.url }}">Open record</a>
            <a class="button-link-muted" href="{{ document.data.file }}">Open file</a>
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
</section>
