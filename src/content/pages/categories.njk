---
pagination:
  data: collections.editorialTagList
  size: 1
  alias: currentTag
permalink: "/category/{{ currentTag | slugifyTag }}/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ currentTag | tagLabel }}"
  description: "Reporting filed under the {{ currentTag | tagLabel | lower }} desk."
  ogType: "website"
eleventyExcludeFromCollections: true
---
{% set stories = collections[currentTag] | sortByDateDesc %}
{% set lead = stories[0] %}
{% set leadAuthor = lead.data.author | getAuthor(collections.authorProfiles) if lead else null %}
<section class="page-shell page-shell--bento" data-pagefind-body>
  <header class="page-header">
    <div class="sr-only" aria-hidden="true">
      <span data-pagefind-meta="type">Desk page</span>
      <span data-pagefind-filter="desk">{{ currentTag | tagLabel }}</span>
    </div>
    <p class="section-kicker">Editorial desk</p>
    <h1 class="page-title">{{ currentTag | tagLabel }}</h1>
    <p class="page-description">This desk collects reporting filed under {{ currentTag | tagLabel | lower }}. New work appears first and the rest stays in the archive.</p>
    <div class="meta-row mt-4">
      <span>{{ stories | length }} {% if stories | length == 1 %}piece{% else %}pieces{% endif %}</span>
      {% if lead %}<span class="meta-divider">Latest {{ lead.date | displayDate }}</span>{% endif %}
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      <a class="button-link-muted" href="/archives/">Open archive</a>
      <a class="button-link-muted" href="/search/">Search archive</a>
    </div>
    {% if collections.editorialDesks | length > 1 %}
      <div class="mt-4 flex flex-wrap gap-2">
        {% for desk in collections.editorialDesks %}
          {% if desk.tag != currentTag %}
            <a class="story-chip" href="/category/{{ desk.slug }}/">{{ desk.label }}</a>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </header>

  {% if lead %}
    <article class="lead-card news-grid-accent category-lead p-5 md:p-6 math-rank-major" data-math-rank="major">
      <div class="ml-2">
        <p class="section-kicker">{{ lead.data.kicker or "Lead report" }}</p>
        <h2 class="mt-2 max-w-5xl font-display text-[clamp(2rem,3.8vw,3.5rem)] font-semibold leading-[0.96] tracking-tight text-[rgb(var(--ink))]">
          <a class="headline-link" href="{{ lead.url }}">{{ lead.data.title }}</a>
        </h2>
        <div class="meta-row mt-3">
          <span>{{ lead.date | displayDate }}</span>
          {% if leadAuthor %}<span class="meta-divider"><a class="headline-link" href="{{ leadAuthor.url }}">{{ leadAuthor.data.name }}</a></span>{% endif %}
          <span class="meta-divider">{{ lead.templateContent | readingMinutes }} min read</span>
        </div>
        <p class="mt-4 max-w-4xl font-serif text-[1.02rem] leading-relaxed text-[rgb(var(--ink-soft))]">{{ lead.data.description }}</p>
        <div class="mt-4">
          <a class="button-link" href="{{ lead.url }}" data-haptic data-haptic="confirm">Read lead report</a>
        </div>
      </div>
    </article>
  {% endif %}

  {% if stories | length > 1 %}
    <div class="story-bento-grid">
      {% for story in stories %}
        {% if not loop.first %}
          {% set storyAuthor = story.data.author | getAuthor(collections.authorProfiles) %}
          {% set deskRankClass = "math-rank-medium" if loop.index <= 3 else "math-rank-small" %}
          {% set deskRank = "medium" if loop.index <= 3 else "small" %}
          <article class="listing-card card-lift story-bento-card p-4 md:p-5 {{ deskRankClass }}" data-math-rank="{{ deskRank }}">
            <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
              <div class="max-w-4xl">
                <p class="meta-row">
                  <span>{{ story.date | displayDate }}</span>
                  <span class="meta-divider">{{ story.templateContent | readingMinutes }} min read</span>
                </p>
                <h2 class="mt-2 font-serif text-[clamp(1.75rem,1.5rem+0.6vw,2.35rem)] font-semibold leading-tight text-[rgb(var(--ink))]">
                  <a class="headline-link" href="{{ story.url }}">{{ story.data.title }}</a>
                </h2>
                <p class="mt-2 font-serif text-[0.95rem] leading-relaxed text-[rgb(var(--ink-soft))]">{{ story.data.description }}</p>
              </div>
              <div class="meta-row md:text-right">
                <span>{% if storyAuthor %}<a class="headline-link" href="{{ storyAuthor.url }}">{{ storyAuthor.data.name }}</a>{% else %}{{ site.author }}{% endif %}</span>
              </div>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</section>
