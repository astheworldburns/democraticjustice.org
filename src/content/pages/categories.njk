---
pagination:
  data: collections.editorialTagList
  size: 1
  alias: currentTag
permalink: "/category/{{ currentTag | slugifyTag }}/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ currentTag | tagLabel }}"
  description: "Reporting filed under the {{ currentTag | tagLabel | lower }} desk."
  ogType: "website"
eleventyExcludeFromCollections: true
---
{% set stories = collections[currentTag] | sortByDateDesc %}
{% set lead = stories[0] %}
{% set leadAuthor = lead.data.author | getAuthor(collections.authorProfiles) if lead else null %}
<section class="space-y-8" data-pagefind-body>
  <header class="border-b-2 border-[rgb(var(--rule-strong))] pb-8">
    <div class="sr-only" aria-hidden="true">
      <span data-pagefind-meta="type">Desk page</span>
      <span data-pagefind-filter="desk">{{ currentTag | tagLabel }}</span>
    </div>
    <p class="section-kicker">Editorial desk</p>
    <h1 class="mt-3 font-display text-[clamp(2.7rem,5vw,4.5rem)] font-black tracking-tight text-[rgb(var(--ink))]">
      {{ currentTag | tagLabel }}
    </h1>
    <p class="mt-4 max-w-3xl font-serif text-lg leading-relaxed text-[rgb(var(--ink-soft))]">
      This desk collects reporting filed under {{ currentTag | tagLabel | lower }}. New work appears first and the rest stays in the archive.
    </p>
    <div class="meta-row mt-5">
      <span>{{ stories | length }} {% if stories | length == 1 %}piece{% else %}pieces{% endif %}</span>
      {% if lead %}
        <span class="meta-divider">Latest {{ lead.date | displayDate }}</span>
      {% endif %}
    </div>
    <div class="mt-5 flex flex-wrap gap-3">
      <a class="button-link-muted" href="/archives/">Open archive</a>
      <a class="button-link-muted" href="/search/">Search the archive</a>
    </div>
    {% if collections.editorialDesks | length > 1 %}
      <div class="mt-5 flex flex-wrap gap-2">
        {% for desk in collections.editorialDesks %}
          {% if desk.tag != currentTag %}
            <a class="story-chip" href="/category/{{ desk.slug }}/">{{ desk.label }}</a>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </header>

  {% if lead %}
    <article class="lead-card news-grid-accent overflow-hidden p-6 md:p-8">
      <div class="ml-3">
        <p class="section-kicker">{{ lead.data.kicker or "Lead report" }}</p>
        <h2 class="mt-3 max-w-5xl font-display text-[clamp(2.2rem,4.3vw,4rem)] font-black leading-[0.94] tracking-tight text-[rgb(var(--ink))]">
          <a class="headline-link" href="{{ lead.url }}">{{ lead.data.title }}</a>
        </h2>
        <div class="meta-row mt-4">
          <span>{{ lead.date | displayDate }}</span>
          {% if leadAuthor %}
            <span class="meta-divider"><a class="hover:text-[rgb(var(--ink))]" href="{{ leadAuthor.url }}">{{ leadAuthor.data.name }}</a></span>
          {% endif %}
          <span class="meta-divider">{{ lead.templateContent | readingMinutes }} min read</span>
        </div>
        <p class="mt-5 max-w-4xl font-serif text-[clamp(1.12rem,1rem+0.45vw,1.35rem)] leading-relaxed text-[rgb(var(--ink-soft))]">
          {{ lead.data.description }}
        </p>
        <div class="mt-6">
          <a class="button-link" href="{{ lead.url }}">Read the lead report</a>
        </div>
      </div>
    </article>
  {% endif %}

  {% if stories | length > 1 %}
    <div class="grid gap-4">
      {% for story in stories %}
        {% if not loop.first %}
          {% set storyAuthor = story.data.author | getAuthor(collections.authorProfiles) %}
          <article class="listing-card card-lift p-5 md:p-6">
            <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
              <div class="max-w-4xl">
                <p class="meta-row">
                  <span>{{ story.date | displayDate }}</span>
                  <span class="meta-divider">{{ story.templateContent | readingMinutes }} min read</span>
                </p>
                <h2 class="mt-3 font-serif text-[clamp(1.9rem,1.5rem+0.8vw,2.7rem)] font-black leading-tight text-[rgb(var(--ink))]">
                  <a class="headline-link" href="{{ story.url }}">{{ story.data.title }}</a>
                </h2>
                <p class="mt-3 font-serif text-base leading-relaxed text-[rgb(var(--ink-soft))]">
                  {{ story.data.description }}
                </p>
              </div>
              <div class="meta-row md:text-right">
                <span>{% if storyAuthor %}<a class="hover:text-[rgb(var(--ink))]" href="{{ storyAuthor.url }}">{{ storyAuthor.data.name }}</a>{% else %}{{ site.author }}{% endif %}</span>
              </div>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</section>
