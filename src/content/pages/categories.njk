---
pagination:
  data: collections.editorialTagList
  size: 1
  alias: currentTag
permalink: "/category/{{ currentTag | slugifyTag }}/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ currentTag | tagLabel }}"
  description: "Reporting filed under the {{ currentTag | tagLabel | lower }} desk."
eleventyExcludeFromCollections: true
---
{% set stories = collections[currentTag] | reverse %}
<section class="space-y-8">
  <header class="border-b border-stone-900 pb-6">
    <p class="font-ui text-xs font-semibold uppercase tracking-kicker text-stone-500">Editorial Category</p>
    <h1 class="mt-3 font-display text-4xl font-black tracking-tight text-stone-950 md:text-5xl">
      {{ currentTag | tagLabel }}
    </h1>
    <p class="mt-4 max-w-2xl font-serif text-lg leading-relaxed text-stone-700">
      Filed reporting and analysis grouped under the {{ currentTag | tagLabel | lower }} desk.
    </p>
  </header>

  <div class="divide-y divide-stone-300 border-y border-stone-300">
    {% for story in stories %}
      <article class="grid gap-4 py-6 md:grid-cols-[1fr_auto] md:items-start">
        <div>
          <p class="font-ui text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">
            {{ story.data.author or site.author }}
          </p>
          <h2 class="mt-2 font-serif text-3xl font-black leading-tight text-stone-950">
            <a class="hover:text-stone-700" href="{{ story.url }}">{{ story.data.title }}</a>
          </h2>
          <p class="mt-3 max-w-3xl font-serif text-base leading-relaxed text-stone-700">
            {{ story.data.description }}
          </p>
        </div>
        <p class="font-ui text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">
          {{ story.date | displayDate }}
        </p>
      </article>
    {% endfor %}
  </div>
</section>
