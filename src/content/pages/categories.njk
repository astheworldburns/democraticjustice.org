---
pagination:
  data: collections.editorialTagList
  size: 1
  alias: currentTag
permalink: "/category/{{ currentTag | slugifyTag }}/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ currentTag | tagLabel }}"
  description: "Reporting filed under the {{ currentTag | tagLabel | lower }} desk."
  ogType: "website"
eleventyExcludeFromCollections: true
---
{% set stories = collections[currentTag] | sortByDateDesc %}
{% set lead = stories[0] %}
{% set leadAuthor = lead.data.author | getAuthor(collections.authorProfiles) if lead else null %}
<main id="main-content" data-pagefind-body>
  <section aria-labelledby="desk-heading" class="mb-12">
    <div class="sr-only" aria-hidden="true">
      <span data-pagefind-meta="type">Desk page</span>
      <span data-pagefind-filter="desk">{{ currentTag | tagLabel }}</span>
    </div>
    {% set sectionKicker = "Editorial desk" %}{% set sectionTitle = currentTag | tagLabel %}{% set sectionId = "desk-heading" %}
    {% include "components/section-header.njk" %}
    <p class="page-description">This desk collects reporting filed under {{ currentTag | tagLabel | lower }}. New work appears first and the rest stays in the archive.</p>
    {% set metaDesk = null %}{% set metaAuthor = null %}{% set metaAuthorUrl = null %}{% set metaDate = lead.date if lead else null %}{% set metaReadTime = null %}
    <div class="mt-4">{% include "components/meta-row.njk" %}</div>
    <div class="mt-4 flex flex-wrap gap-2">
      <a class="button-link-muted" href="/archives/">Open archive</a>
      <a class="button-link-muted" href="/search/">Search archive</a>
    </div>
    {% if collections.editorialDesks | length > 1 %}
      <div class="mt-4 flex flex-wrap gap-2">
        {% for desk in collections.editorialDesks %}
          {% if desk.tag != currentTag %}
            <a class="story-chip" href="/category/{{ desk.slug }}/">{{ desk.label }}</a>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </section>

  {% if lead %}
    <section aria-labelledby="lead-heading" class="mb-10">
      <article class="card card--featured">
        <span class="card__tag">{{ lead.data.kicker or "Lead report" }}</span>
        <h2 id="lead-heading" class="font-serif text-display-md leading-tight">
          <a class="headline-link" href="{{ lead.url }}">{{ lead.data.title }}</a>
        </h2>
        {% set metaDate = lead.date %}{% set metaAuthor = leadAuthor.data.name if leadAuthor else null %}{% set metaAuthorUrl = leadAuthor.url if leadAuthor else null %}{% set metaDesk = null %}{% set metaReadTime = lead.templateContent | readingMinutes %}
        <div class="mt-3">{% include "components/meta-row.njk" %}</div>
        <p class="mt-4 text-ink-secondary">{{ lead.data.description }}</p>
      </article>
    </section>
  {% endif %}

  {% if stories | length > 1 %}
    <section aria-labelledby="more-heading">
      {% set sectionKicker = "More" %}{% set sectionTitle = "Desk reporting" %}{% set sectionId = "more-heading" %}
      {% include "components/section-header.njk" %}
      <div class="bento-grid">
        {% for story in stories %}
          {% if not loop.first %}
            {% set storyAuthor = story.data.author | getAuthor(collections.authorProfiles) %}
            <article class="card bento-4">
              <h3 class="font-serif text-xl leading-tight text-ink"><a class="headline-link" href="{{ story.url }}">{{ story.data.title }}</a></h3>
              <p class="mt-2 text-sm text-ink-secondary">{{ story.data.description }}</p>
              {% set metaDate = story.date %}{% set metaAuthor = storyAuthor.data.name if storyAuthor else site.author %}{% set metaAuthorUrl = storyAuthor.url if storyAuthor else null %}{% set metaDesk = null %}{% set metaReadTime = story.templateContent | readingMinutes %}
              <div class="mt-3">{% include "components/meta-row.njk" %}</div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}
</main>
