---
layout: layouts/base.njk
title: Search
description: Search the Democratic Justice archive.
permalink: /search/index.html
ogType: website
extraHead: |
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
pageScripts: |
  <script src="/pagefind/pagefind-ui.js"></script>
  <script>
    window.addEventListener("DOMContentLoaded", () => {
      new PagefindUI({
        element: "#news-search",
        showEmptyFilters: false,
        showSubResults: true,
        excerptLength: 24,
        resetStyles: false,
        translations: {
          placeholder: "Search the archive"
        }
      });
    });
  </script>
---
<section class="space-y-8">
  <header class="border-b-2 border-[rgb(var(--rule-strong))] pb-6">
    <p class="section-kicker">Archive search</p>
    <h1 class="mt-3 font-display text-[clamp(2.7rem,5vw,4.4rem)] font-black tracking-tight text-[rgb(var(--ink))]">
      Search the reporting archive
    </h1>
    <p class="mt-4 max-w-3xl font-serif text-lg leading-relaxed text-[rgb(var(--ink-soft))]">
      Search the archive by name, subject, desk, or date.
    </p>
  </header>

  <div class="search-shell p-5 md:p-7">
    <p class="section-kicker">Search tips</p>
    <p class="mt-2 max-w-3xl font-serif text-base leading-relaxed text-[rgb(var(--ink-soft))]">
      Start with a name, subject, organization, or desk. Follow the results into the archive.
    </p>
    <div class="mt-6" id="news-search"></div>
  </div>
</section>
