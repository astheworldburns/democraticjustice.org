{# Token migration: arbitrary values replaced — Phase 1B #}
---
layout: layouts/base.njk
title: Archives
description: The public record of what Democratic Justice has published.
permalink: /archives/index.html
ogType: website
---
<section class="page-shell page-shell--bento" data-pagefind-body>
  <header class="page-header">
    <div class="sr-only" aria-hidden="true">
      <span data-pagefind-meta="type">Archive page</span>
    </div>
    <p class="section-kicker">Archive</p>
    <h1 class="page-title">Reporting archive</h1>
    <p class="page-description">This is the public record of what we publish. Each story stays in place.</p>
    <div class="mt-4 flex flex-wrap gap-2">
      <a class="button-link-muted" href="/search/">Search archive</a>
      <a class="button-link-muted" href="/rss/">Follow by RSS</a>
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      {% for bucket in collections.articleArchiveYears %}
        <a class="story-chip" href="#year-{{ bucket.year }}">{{ bucket.year }}</a>
      {% endfor %}
    </div>
  </header>

  <div class="space-y-8">
    {% for yearBucket in collections.articleArchiveYears %}
      <section id="year-{{ yearBucket.year }}" class="space-y-4">
        <div class="flex items-end justify-between border-b border-border pb-3">
          <h2 class="font-display text-3xl font-semibold tracking-tight text-ink">{{ yearBucket.year }}</h2>
          <p class="section-kicker">{{ yearBucket.months | length }} {% if yearBucket.months | length == 1 %}month{% else %}months{% endif %}</p>
        </div>

        <div class="archive-month-grid">
          {% for monthBucket in yearBucket.months %}
            {% set monthRankClass = "math-rank-major" if loop.first else "math-rank-medium" %}
            {% set monthRank = "major" if loop.first else "medium" %}
            <section class="listing-card archive-month-card p-4 md:p-5 {{ monthRankClass }}" data-math-rank="{{ monthRank }}">
              <div class="grid gap-4 lg:grid-cols-[13rem_minmax(0,1fr)]">
                <div>
                  <p class="section-kicker">{{ monthBucket.year }}</p>
                  <h3 class="mt-2 font-display text-3xl font-semibold tracking-tight text-ink">{{ monthBucket.label }}</h3>
                </div>

                <div class="divide-y divide-[rgba(var(--rule),0.82)]">
                  {% for story in monthBucket.posts %}
                    {% set storyAuthor = story.data.author | getAuthor(collections.authorProfiles) %}
                    <article class="archive-story-row grid gap-3 py-3 md:grid-cols-[minmax(0,1fr)_auto] md:items-start">
                      <div>
                        <h4 class="font-serif text-2xl font-semibold leading-tight text-ink">
                          <a class="headline-link" href="{{ story.url }}">{{ story.data.title }}</a>
                        </h4>
                        <p class="mt-2 max-w-3xl font-serif text-base leading-relaxed text-ink-secondary">{{ story.data.description }}</p>
                      </div>
                      <div class="meta-row md:text-right">
                        <span>{{ story.date | displayDate }}</span>
                        <span>{% if storyAuthor %}<a class="headline-link" href="{{ storyAuthor.url }}">{{ storyAuthor.data.name }}</a>{% else %}{{ site.author }}{% endif %}</span>
                      </div>
                    </article>
                  {% endfor %}
                </div>
              </div>
            </section>
          {% endfor %}
        </div>
      </section>
    {% endfor %}
  </div>
</section>
