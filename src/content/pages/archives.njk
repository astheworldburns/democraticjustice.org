---
layout: layouts/base.njk
title: Archives
description: Browse Democratic Justice reporting by publication month.
permalink: /archives/index.html
---
<section class="space-y-8">
  <header class="border-b border-stone-900 pb-6">
    <p class="font-ui text-xs font-semibold uppercase tracking-kicker text-stone-500">Archive</p>
    <h1 class="mt-3 font-display text-4xl font-black tracking-tight text-stone-950 md:text-5xl">
      Reporting Archive
    </h1>
    <p class="mt-4 max-w-3xl font-serif text-lg leading-relaxed text-stone-700">
      A chronological index of published reporting, grouped by month so the publication history remains legible as the archive grows.
    </p>
  </header>

  <div class="space-y-10">
    {% for bucket in collections.articleArchive %}
      <section class="grid gap-5 border-b border-stone-300 pb-8 lg:grid-cols-[14rem_minmax(0,1fr)]">
        <div>
          <p class="font-ui text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">{{ bucket.year }}</p>
          <h2 class="mt-2 font-display text-3xl font-black tracking-tight text-stone-950">
            {{ bucket.label }}
          </h2>
        </div>
        <div class="divide-y divide-stone-200">
          {% for story in bucket.posts %}
            <article class="grid gap-3 py-4 md:grid-cols-[1fr_auto] md:items-start">
              <div>
                <h3 class="font-serif text-2xl font-black leading-tight text-stone-950">
                  <a class="hover:text-stone-700" href="{{ story.url }}">{{ story.data.title }}</a>
                </h3>
                <p class="mt-2 max-w-3xl font-serif text-base leading-relaxed text-stone-700">
                  {{ story.data.description }}
                </p>
              </div>
              <p class="font-ui text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">
                {{ story.date | displayDate }}
              </p>
            </article>
          {% endfor %}
        </div>
      </section>
    {% endfor %}
  </div>
</section>

