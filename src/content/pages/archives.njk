---
layout: layouts/base.njk
title: Archives
description: The public record of what Democratic Justice has published.
permalink: /archives/index.html
ogType: website
---
<section class="space-y-8" data-pagefind-body>
  <header class="border-b-2 border-[rgb(var(--rule-strong))] pb-6">
    <div class="sr-only" aria-hidden="true">
      <span data-pagefind-meta="type">Archive page</span>
    </div>
    <p class="section-kicker">Archive</p>
    <h1 class="mt-3 font-display text-[clamp(2.7rem,5vw,4.4rem)] font-black tracking-tight text-[rgb(var(--ink))]">
      Reporting archive
    </h1>
    <p class="mt-4 max-w-3xl font-serif text-lg leading-relaxed text-[rgb(var(--ink-soft))]">
      This is the public record of what we have published. Each story stays in place.
    </p>
    <div class="mt-5 flex flex-wrap gap-3">
      <a class="button-link-muted" href="/search/">Search the archive</a>
      <a class="button-link-muted" href="/rss/">Follow by RSS</a>
    </div>
    <div class="mt-5 flex flex-wrap gap-2">
      {% for bucket in collections.articleArchiveYears %}
        <a class="story-chip" href="#year-{{ bucket.year }}">{{ bucket.year }}</a>
      {% endfor %}
    </div>
  </header>

  <div class="space-y-10">
    {% for yearBucket in collections.articleArchiveYears %}
      <section id="year-{{ yearBucket.year }}" class="space-y-5">
        <div class="flex items-end justify-between border-b border-[rgb(var(--rule-strong))] pb-3">
          <h2 class="font-display text-3xl font-black tracking-tight text-[rgb(var(--ink))]">{{ yearBucket.year }}</h2>
          <p class="section-kicker">{{ yearBucket.months | length }} {% if yearBucket.months | length == 1 %}month{% else %}months{% endif %}</p>
        </div>
        <div class="space-y-6">
          {% for monthBucket in yearBucket.months %}
            <section class="listing-card p-5 md:p-6">
              <div class="grid gap-5 lg:grid-cols-[14rem_minmax(0,1fr)]">
                <div>
                  <p class="section-kicker">{{ monthBucket.year }}</p>
                  <h3 class="mt-2 font-display text-3xl font-black tracking-tight text-[rgb(var(--ink))]">
                    {{ monthBucket.label }}
                  </h3>
                </div>
                <div class="divide-y divide-[rgba(var(--rule),0.92)]">
                  {% for story in monthBucket.posts %}
                    {% set storyAuthor = story.data.author | getAuthor(collections.authorProfiles) %}
                    <article class="grid gap-3 py-4 md:grid-cols-[minmax(0,1fr)_auto] md:items-start">
                      <div>
                        <h4 class="font-serif text-2xl font-black leading-tight text-[rgb(var(--ink))]">
                          <a class="headline-link" href="{{ story.url }}">{{ story.data.title }}</a>
                        </h4>
                        <p class="mt-2 max-w-3xl font-serif text-base leading-relaxed text-[rgb(var(--ink-soft))]">
                          {{ story.data.description }}
                        </p>
                      </div>
                      <div class="meta-row md:text-right">
                        <span>{{ story.date | displayDate }}</span>
                        <span>{% if storyAuthor %}<a class="hover:text-[rgb(var(--ink))]" href="{{ storyAuthor.url }}">{{ storyAuthor.data.name }}</a>{% else %}{{ site.author }}{% endif %}</span>
                      </div>
                    </article>
                  {% endfor %}
                </div>
              </div>
            </section>
          {% endfor %}
        </div>
      </section>
    {% endfor %}
  </div>
</section>
