---
layout: layouts/base.njk
title: Archives
description: The public record of what Democratic Justice has published.
permalink: /archives/index.html
ogType: website
---
<main id="main-content" data-pagefind-body>
  <section aria-labelledby="archives-heading" class="mb-12">
    <div class="sr-only" aria-hidden="true">
      <span data-pagefind-meta="type">Archive page</span>
    </div>
    {% set sectionKicker = "Archive" %}{% set sectionTitle = "Reporting archive" %}{% set sectionId = "archives-heading" %}
    {% include "components/section-header.njk" %}
    <p class="page-description">This is the public record of what we publish. Each story stays in place.</p>
    <div class="mt-4 flex flex-wrap gap-2">
      <a class="button-link-muted" href="/search/">Search archive</a>
      <a class="button-link-muted" href="/rss/">Follow by RSS</a>
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      {% for bucket in collections.articleArchiveYears %}
        <a class="story-chip" href="#year-{{ bucket.year }}">{{ bucket.year }}</a>
      {% endfor %}
    </div>
  </section>

  <div class="space-y-10">
    {% for yearBucket in collections.articleArchiveYears %}
      <section id="year-{{ yearBucket.year }}" aria-labelledby="year-heading-{{ yearBucket.year }}" class="space-y-4">
        {% set sectionKicker = "Year" %}{% set sectionTitle = yearBucket.year %}{% set sectionId = "year-heading-" + yearBucket.year %}
        {% include "components/section-header.njk" %}
        <div class="bento-grid">
          {% for monthBucket in yearBucket.months %}
            <section class="card bento-6" aria-labelledby="month-{{ yearBucket.year }}-{{ loop.index }}">
              <h3 id="month-{{ yearBucket.year }}-{{ loop.index }}" class="font-serif text-2xl">{{ monthBucket.label }}</h3>
              <div class="mt-4 space-y-4">
                {% for story in monthBucket.posts %}
                  {% set storyAuthor = story.data.author | getAuthor(collections.authorProfiles) %}
                  <article class="border-t border-border-subtle pt-4 first:border-t-0 first:pt-0">
                    <h4 class="font-serif text-xl leading-tight text-ink">
                      <a class="headline-link" href="{{ story.url }}">{{ story.data.title }}</a>
                    </h4>
                    <p class="mt-2 text-sm text-ink-secondary">{{ story.data.description }}</p>
                    {% set metaDate = story.date %}{% set metaAuthor = storyAuthor.data.name if storyAuthor else site.author %}{% set metaAuthorUrl = storyAuthor.url if storyAuthor else null %}{% set metaDesk = null %}{% set metaReadTime = story.templateContent | readingMinutes %}
                    <div class="mt-3">{% include "components/meta-row.njk" %}</div>
                  </article>
                {% endfor %}
              </div>
            </section>
          {% endfor %}
        </div>
      </section>
    {% endfor %}
  </div>
</main>
