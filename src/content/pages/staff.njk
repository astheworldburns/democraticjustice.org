---
layout: layouts/base.njk
title: Staff
description: Meet the bylines behind Democratic Justice.
permalink: /staff/index.html
ogType: website
---
<section class="page-shell page-shell--bento" data-pagefind-body>
  <header class="page-header">
    <p class="section-kicker">Newsroom</p>
    <h1 class="page-title">Staff</h1>
    <p class="page-description">These are the bylines behind Democratic Justice. Each reporter's work stays in one archive.</p>
  </header>

  <div class="staff-bento-grid">
    {% for reporter in collections.authorProfiles %}
      {% set reporterStories = collections.article | articlesByAuthor(reporter.fileSlug) %}
      <article class="author-card card-lift staff-bento-card p-4">
        <div class="sr-only" aria-hidden="true">
          <span data-pagefind-filter="author">{{ reporter.data.name }}</span>
          <span data-pagefind-meta="type">Staff directory</span>
        </div>
        <div class="flex items-start gap-3">
          {% if reporter.data.headshot %}
            {% image reporter.data.headshot, reporter.data.name, "72px", "h-16 w-16 rounded-full object-cover" %}
          {% else %}
            <div class="author-avatar">{{ reporter.data.name | initials }}</div>
          {% endif %}
          <div>
            <h2 class="font-serif text-2xl font-semibold leading-tight text-[rgb(var(--ink))]">
              <a class="headline-link" href="{{ reporter.url }}">{{ reporter.data.name }}</a>
            </h2>
            <p class="mt-1 font-mono text-[0.58rem] uppercase tracking-[0.1em] text-[rgb(var(--ink-muted))]">{{ reporter.data.role }}</p>
          </div>
        </div>
        <p class="mt-3 font-serif text-[0.92rem] leading-relaxed text-[rgb(var(--ink-soft))]">{{ reporter.data.bio or reporter.data.short_bio }}</p>
        <div class="meta-row mt-4"><span>{{ reporterStories | length }} published</span></div>
      </article>
    {% endfor %}
  </div>
</section>
