---
layout: layouts/base.njk
title: Staff
description: Meet the bylines behind Democratic Justice.
permalink: /staff/index.html
ogType: website
---
<main id="main-content" data-pagefind-body>
  <section aria-labelledby="staff-heading">
    {% set sectionKicker = "Newsroom" %}{% set sectionTitle = "Staff" %}{% set sectionId = "staff-heading" %}
    {% include "components/section-header.njk" %}
    <p class="page-description">These are the bylines behind Democratic Justice. Each reporter's work stays in one archive.</p>

    <div class="bento-grid mt-8">
      {% for reporter in collections.authorProfiles %}
        {% set reporterStories = collections.article | articlesByAuthor(reporter.fileSlug) %}
        <article class="card bento-4">
          <div class="sr-only" aria-hidden="true">
            <span data-pagefind-filter="author">{{ reporter.data.name }}</span>
            <span data-pagefind-meta="type">Staff directory</span>
          </div>
          <div class="flex items-start gap-3">
            {% if reporter.data.headshot %}
              {% image reporter.data.headshot, reporter.data.name, "72px", "h-16 w-16 rounded-full object-cover" %}
            {% else %}
              <div class="author-avatar">{{ reporter.data.name | initials }}</div>
            {% endif %}
            <div>
              <h2 class="font-serif text-2xl font-semibold leading-tight text-ink">
                <a class="headline-link" href="{{ reporter.url }}">{{ reporter.data.name }}</a>
              </h2>
              <p class="mt-1 font-mono text-xs uppercase tracking-wide text-ink-muted">{{ reporter.data.role }}</p>
            </div>
          </div>
          <p class="mt-3 font-serif text-sm leading-relaxed text-ink-secondary">{{ reporter.data.bio or reporter.data.short_bio }}</p>
          {% set metaDesk = null %}{% set metaAuthor = null %}{% set metaAuthorUrl = null %}{% set metaDate = null %}{% set metaReadTime = null %}
          <div class="meta-row mt-4"><span>{{ reporterStories | length }} published</span></div>
        </article>
      {% endfor %}
    </div>
  </section>
</main>
