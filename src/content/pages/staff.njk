---
layout: layouts/base.njk
title: Staff
description: Meet the bylines behind Democratic Justice.
permalink: /staff/index.html
ogType: website
---
<section class="space-y-8" data-pagefind-body>
  <header class="border-b-2 border-[rgb(var(--rule-strong))] pb-6">
    <p class="section-kicker">Newsroom</p>
    <h1 class="mt-3 font-display text-[clamp(2.7rem,5vw,4.4rem)] font-black tracking-tight text-[rgb(var(--ink))]">
      Staff
    </h1>
    <p class="mt-4 max-w-3xl font-serif text-lg leading-relaxed text-[rgb(var(--ink-soft))]">
      Reporter bios, beats, and recent work. Every byline follows the same standards and appears in the same searchable archive.
    </p>
  </header>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {% for reporter in collections.authorProfiles %}
      {% set reporterStories = collections.article | articlesByAuthor(reporter.fileSlug) %}
      {% set reporterTags = reporterStories | uniqueEditorialTags(4) %}
      <article class="author-card card-lift p-5">
        <div class="sr-only" aria-hidden="true">
          <span data-pagefind-filter="author">{{ reporter.data.name }}</span>
          <span data-pagefind-meta="type">Staff directory</span>
        </div>
        <div class="flex items-start gap-4">
          {% if reporter.data.headshot %}
            {% image reporter.data.headshot, reporter.data.name, "72px", "h-16 w-16 rounded-full object-cover" %}
          {% else %}
            <div class="author-avatar">{{ reporter.data.name | initials }}</div>
          {% endif %}
          <div>
            <h2 class="font-serif text-2xl font-black leading-tight text-[rgb(var(--ink))]">
              <a class="headline-link" href="{{ reporter.url }}">{{ reporter.data.name }}</a>
            </h2>
            <p class="mt-1 font-ui text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--ink-muted))]">
              {{ reporter.data.role }}
            </p>
          </div>
        </div>
        <p class="mt-4 font-serif text-sm leading-relaxed text-[rgb(var(--ink-soft))]">
          {{ reporter.data.bio or reporter.data.short_bio }}
        </p>
        <div class="meta-row mt-5">
          <span>{{ reporterStories | length }} published</span>
        </div>
        {% if reporterTags | length %}
          <div class="mt-4 flex flex-wrap gap-2">
            {% for tag in reporterTags %}
              <a class="story-chip" href="/category/{{ tag | slugifyTag }}/">{{ tag | tagLabel }}</a>
            {% endfor %}
          </div>
        {% endif %}
      </article>
    {% endfor %}
  </div>
</section>
