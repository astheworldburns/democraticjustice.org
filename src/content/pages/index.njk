---
layout: layouts/base.njk
title: Democratic Justice
description: Investigative journalism and political accountability reporting from West Virginia.
permalink: /
ogType: website
---
{% set stories = collections.article | sortByDateDesc %}
{% set lead = stories[0] %}
{% set leadAuthor = lead.data.author | getAuthor(collections.authorProfiles) if lead else null %}
<div class="space-y-14" data-pagefind-body>
  <section class="space-y-8 border-b-2 border-[rgb(var(--rule-strong))] pb-10">
    <div class="grid gap-8 xl:grid-cols-[minmax(0,1.6fr)_minmax(18rem,0.82fr)]">
      <div class="space-y-6">
        <div class="flex flex-col gap-4 border-b border-[rgba(var(--rule),0.92)] pb-5 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="section-kicker">Front page</p>
            <h1 class="mt-3 font-display text-[clamp(2.9rem,5.8vw,5rem)] font-black leading-[0.92] tracking-tight text-[rgb(var(--ink))]">
              Accountability reporting shaped like a publication, not a content feed
            </h1>
          </div>
          <p class="max-w-xl font-serif text-lg leading-relaxed text-[rgb(var(--ink-soft))]">
            Democratic Justice is organized as a living desk: searchable, syndication-ready, and structured so serious reporting can accumulate with weight.
          </p>
        </div>

        {% if lead %}
          <article class="lead-card news-grid-accent overflow-hidden p-6 md:p-8">
            <div class="ml-3">
              <p class="section-kicker">{{ lead.data.kicker or "Lead report" }}</p>
              <h2 class="mt-3 max-w-5xl font-display text-[clamp(2.35rem,4.7vw,4.9rem)] font-black leading-[0.94] tracking-tight text-[rgb(var(--ink))]">
                <a class="headline-link" href="{{ lead.url }}">{{ lead.data.title }}</a>
              </h2>
              <div class="meta-row mt-4">
                <span>{{ lead.date | displayDate }}</span>
                <span class="meta-divider">By {% if leadAuthor %}<a class="hover:text-[rgb(var(--ink))]" href="{{ leadAuthor.url }}">{{ leadAuthor.data.name }}</a>{% else %}{{ site.author }}{% endif %}</span>
                <span class="meta-divider">{{ lead.templateContent | readingMinutes }} min read</span>
              </div>
              {% if lead.data.tags %}
                <div class="mt-4 flex flex-wrap gap-3">
                  {% for tag in lead.data.tags %}
                    {% if tag != "article" %}
                      <a class="story-chip" href="/category/{{ tag | slugifyTag }}/">{{ tag | tagLabel }}</a>
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}
              <p class="mt-6 max-w-4xl font-serif text-[clamp(1.18rem,1rem+0.4vw,1.5rem)] leading-relaxed text-[rgb(var(--ink-soft))]">
              {{ lead.data.description }}
            </p>
            <p class="mt-6 max-w-4xl font-serif text-base leading-8 text-[rgb(var(--ink-soft))]">
              {{ lead.templateContent | striptags | truncate(430, true, "…") }}
            </p>
              <div class="mt-8 flex flex-wrap gap-4">
                <a class="button-link" href="{{ lead.url }}">Read the full report</a>
                <a class="button-link-muted" href="/search/">Search the archive</a>
              </div>
            </div>
          </article>
        {% endif %}
      </div>

      <aside class="space-y-5">
        <section class="stat-card">
          <p class="section-kicker">Edition note</p>
          <p class="stat-card__value">{{ collections.article | length }}</p>
          <p class="stat-card__caption">
            Published pieces in the archive, organized into {{ collections.editorialDesks | length }} editorial desks and distributed through a full-content feed.
          </p>
        </section>

        <section class="rail-card p-5">
          <p class="section-kicker">Newsroom brief</p>
          <p class="mt-3 font-serif text-lg leading-relaxed text-[rgb(var(--ink-soft))]">
            The platform is designed for long-form accountability work: durable URLs, text-first reading, and publication-wide search that runs without a hosted backend.
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a class="button-link" href="/about/">Read the mission</a>
            <a class="button-link-muted" href="/feed.xml">Follow by RSS</a>
          </div>
        </section>

        {% if collections.editorialDesks | length %}
          <section class="rail-card p-5">
            <p class="section-kicker">Desk map</p>
            <div class="mt-4 space-y-4">
              {% for desk in collections.editorialDesks %}
                <article class="border-b border-[rgba(var(--rule),0.92)] pb-4 last:border-b-0 last:pb-0">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="font-serif text-xl font-black leading-tight text-[rgb(var(--ink))]">
                        <a class="headline-link" href="/category/{{ desk.slug }}/">{{ desk.label }}</a>
                      </h3>
                      {% if desk.latest %}
                        <p class="mt-2 font-serif text-sm leading-relaxed text-[rgb(var(--ink-soft))]">
                          Latest: <a class="headline-link" href="{{ desk.latest.url }}">{{ desk.latest.data.title }}</a>
                        </p>
                      {% endif %}
                    </div>
                    <span class="font-ui text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--ink-muted))]">
                      {{ desk.count }}
                    </span>
                  </div>
                </article>
              {% endfor %}
            </div>
          </section>
        {% endif %}
      </aside>
    </div>
  </section>

  {% if stories | length > 1 %}
    <section class="space-y-6">
      <div class="flex items-end justify-between border-b border-[rgb(var(--rule-strong))] pb-3">
        <h2 class="font-display text-3xl font-black tracking-tight text-[rgb(var(--ink))]">Recent filing</h2>
        <p class="section-kicker">Broadsheet grid</p>
      </div>
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-6">
        {% for story in stories %}
          {% if not loop.first %}
            {% set storyAuthor = story.data.author | getAuthor(collections.authorProfiles) %}
            <article class="story-card card-lift p-5 md:p-6 {% if loop.index == 2 %}md:col-span-2 xl:col-span-3{% else %}xl:col-span-2{% endif %}">
              <p class="meta-row">
                <span>{{ story.date | displayDate }}</span>
                {% if storyAuthor %}
                  <span class="meta-divider"><a class="hover:text-[rgb(var(--ink))]" href="{{ storyAuthor.url }}">{{ storyAuthor.data.name }}</a></span>
                {% endif %}
              </p>
              <h3 class="mt-3 font-serif text-[clamp(1.7rem,1.4rem+0.6vw,2.25rem)] font-black leading-tight text-[rgb(var(--ink))]">
                <a class="headline-link" href="{{ story.url }}">{{ story.data.title }}</a>
              </h3>
              <p class="mt-3 font-serif text-base leading-relaxed text-[rgb(var(--ink-soft))]">
                {{ story.data.description }}
              </p>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}

  <section class="space-y-6">
    <div class="flex items-end justify-between border-b border-[rgb(var(--rule-strong))] pb-3">
      <h2 class="font-display text-3xl font-black tracking-tight text-[rgb(var(--ink))]">How the desk is built</h2>
      <p class="section-kicker">Static-first features</p>
    </div>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <article class="stat-card">
        <p class="section-kicker">Search</p>
        <p class="stat-card__value">Static</p>
        <p class="stat-card__caption">Full-text search runs through Pagefind, so readers can move through the archive without a hosted search service.</p>
      </article>
      <article class="stat-card">
        <p class="section-kicker">Publishing</p>
        <p class="stat-card__value">Git-backed</p>
        <p class="stat-card__caption">Writers publish structured content through Sveltia CMS while the source stays portable and reviewable.</p>
      </article>
      <article class="stat-card">
        <p class="section-kicker">Delivery</p>
        <p class="stat-card__value">Edge</p>
        <p class="stat-card__caption">Cloudflare Pages distributes the build globally, preserving speed and resilience during traffic spikes.</p>
      </article>
      <article class="stat-card">
        <p class="section-kicker">Syndication</p>
        <p class="stat-card__value">Full HTML</p>
        <p class="stat-card__caption">The RSS feed carries complete article markup so newsletters and downstream readers inherit the full reporting package.</p>
      </article>
    </div>
  </section>

  {% if collections.authorProfiles | length %}
    <section class="space-y-6">
      <div class="flex items-end justify-between border-b border-[rgb(var(--rule-strong))] pb-3">
        <h2 class="font-display text-3xl font-black tracking-tight text-[rgb(var(--ink))]">Bylines</h2>
        <p class="section-kicker">Newsroom</p>
      </div>
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {% for reporter in collections.authorProfiles %}
          {% set reporterStories = collections.article | articlesByAuthor(reporter.fileSlug) %}
          {% set reporterTags = reporterStories | uniqueEditorialTags(3) %}
          <article class="author-card card-lift p-5">
            <div class="flex items-start gap-4">
              {% if reporter.data.headshot %}
                {% image reporter.data.headshot, reporter.data.name, "72px", "h-16 w-16 rounded-full object-cover" %}
              {% else %}
                <div class="author-avatar">{{ reporter.data.name | initials }}</div>
              {% endif %}
              <div>
                <h3 class="font-serif text-2xl font-black leading-tight text-[rgb(var(--ink))]">
                  <a class="headline-link" href="{{ reporter.url }}">{{ reporter.data.name }}</a>
                </h3>
                <p class="mt-1 font-ui text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--ink-muted))]">
                  {{ reporter.data.role }}
                </p>
              </div>
            </div>
            <p class="mt-4 font-serif text-sm leading-relaxed text-[rgb(var(--ink-soft))]">
              {{ reporter.data.short_bio }}
            </p>
            <div class="meta-row mt-5">
              <span>{{ reporterStories | length }} filed</span>
            </div>
            {% if reporterTags | length %}
              <div class="mt-4 flex flex-wrap gap-2">
                {% for tag in reporterTags %}
                  <a class="story-chip" href="/category/{{ tag | slugifyTag }}/">{{ tag | tagLabel }}</a>
                {% endfor %}
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </section>
  {% endif %}
</div>
