---
layout: layouts/base.njk
title: Democratic Justice
description: Reporting on power, elections, parties, and public failure.
permalink: /
ogType: website
---
{% set proofMarkDaySrc = site.proofMarkDay ~ "?v=" ~ buildVersion %}
{% set proofMarkNightSrc = site.proofMarkNight ~ "?v=" ~ buildVersion %}
{% set proofMarkPrintSrc = site.proofMarkPrint ~ "?v=" ~ buildVersion %}
{% set stories = collections.publishedArticle | sortByDateDesc %}
{% set lead = stories[0] %}
{% set leadAuthor = lead.data.author | getAuthor(collections.authorProfiles) if lead else null %}
<div class="space-y-14" data-pagefind-body>
  {% if lead %}
    <section class="space-y-8 border-b-2 border-[rgb(var(--rule-strong))] pb-10">
      <div class="grid gap-8 xl:grid-cols-[minmax(0,1.6fr)_minmax(18rem,0.82fr)]">
        <article class="lead-card news-grid-accent overflow-hidden p-6 md:p-8">
          <div class="ml-3">
            <p class="section-kicker">{{ lead.data.kicker or "Lead report" }}</p>
            <h1 class="mt-3 max-w-5xl font-display text-[clamp(2.45rem,4.9vw,5rem)] font-black leading-[0.94] tracking-tight text-[rgb(var(--ink))]">
              <a class="headline-link" href="{{ lead.url }}">{{ lead.data.title }}</a>
            </h1>
            <div class="meta-row mt-4">
              <span>{{ lead.date | displayDate }}</span>
              <span class="meta-divider">By {% if leadAuthor %}<a class="hover:text-[rgb(var(--ink))]" href="{{ leadAuthor.url }}">{{ leadAuthor.data.name }}</a>{% else %}{{ site.name }}{% endif %}</span>
              <span class="meta-divider">{{ lead.templateContent | readingMinutes }} min read</span>
            </div>
            {% if lead.data.tags %}
              <div class="mt-4 flex flex-wrap gap-3">
                {% for tag in lead.data.tags %}
                  {% if tag != "article" %}
                    <a class="story-chip" href="/category/{{ tag | slugifyTag }}/">{{ tag | tagLabel }}</a>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
            <p class="mt-6 max-w-4xl font-serif text-[clamp(1.18rem,1rem+0.4vw,1.5rem)] leading-relaxed text-[rgb(var(--ink-soft))]">
              {{ lead.data.description }}
            </p>
            <p class="mt-6 max-w-4xl font-serif text-base leading-8 text-[rgb(var(--ink-soft))]">
              {{ lead.templateContent | excerptText(430) }}
            </p>
            <div class="mt-8 flex flex-wrap gap-4">
              <a class="button-link" href="{{ lead.url }}">Read the record</a>
              <a class="button-link-muted" href="/archives/">Browse the archive</a>
            </div>
          </div>
        </article>

        <aside class="space-y-5">
          <section class="rail-card p-5">
            <p class="section-kicker">Mission</p>
            <h2 class="mt-3 font-display text-3xl font-black leading-tight tracking-tight text-[rgb(var(--ink))]">
              Reporting readers can check
            </h2>
            <p class="mt-4 font-serif text-base leading-relaxed text-[rgb(var(--ink-soft))]">
              Every story opens with a Proof Card and carries the source documents behind it. We report on power, elections, parties, and public failure.
            </p>
            <div class="mt-5 flex flex-wrap gap-3">
              <a class="button-link" href="/about/">Read the mission</a>
              <a class="button-link-muted" href="/rss/">Follow by RSS</a>
            </div>
          </section>

          {% if collections.editorialDesks | length %}
            <section class="rail-card p-5">
              <p class="section-kicker">Editorial desks</p>
              <div class="mt-4 space-y-4">
                {% for desk in collections.editorialDesks %}
                  <article class="border-b border-[rgba(var(--rule),0.92)] pb-4 last:border-b-0 last:pb-0">
                    <div class="flex items-start justify-between gap-4">
                      <div>
                        <h2 class="font-serif text-xl font-black leading-tight text-[rgb(var(--ink))]">
                          <a class="headline-link" href="/category/{{ desk.slug }}/">{{ desk.label }}</a>
                        </h2>
                        {% if desk.latest %}
                          <p class="mt-2 font-serif text-sm leading-relaxed text-[rgb(var(--ink-soft))]">
                            Latest: <a class="headline-link" href="{{ desk.latest.url }}">{{ desk.latest.data.title }}</a>
                          </p>
                        {% endif %}
                      </div>
                      <span class="font-ui text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--ink-muted))]">
                        {{ desk.count }}
                      </span>
                    </div>
                  </article>
                {% endfor %}
              </div>
            </section>
          {% endif %}
        </aside>
      </div>
    </section>
  {% endif %}

  {% if stories | length > 1 %}
    <section class="space-y-6">
      <div class="flex items-end justify-between border-b border-[rgb(var(--rule-strong))] pb-3">
        <div>
          <p class="section-kicker">Archive</p>
          <h2 class="mt-2 font-display text-3xl font-black tracking-tight text-[rgb(var(--ink))]">Reporting archive</h2>
        </div>
        <a class="button-link-muted" href="/archives/">Open archive</a>
      </div>
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-6">
        {% for story in stories %}
          {% if not loop.first %}
            {% set storyAuthor = story.data.author | getAuthor(collections.authorProfiles) %}
            <article class="story-card card-lift p-5 md:p-6 {% if loop.index == 2 %}md:col-span-2 xl:col-span-3{% else %}xl:col-span-2{% endif %}">
              <p class="meta-row">
                <span>{{ story.date | displayDate }}</span>
                {% if storyAuthor %}
                  <span class="meta-divider"><a class="hover:text-[rgb(var(--ink))]" href="{{ storyAuthor.url }}">{{ storyAuthor.data.name }}</a></span>
                {% endif %}
              </p>
              <h3 class="mt-3 font-serif text-[clamp(1.7rem,1.4rem+0.6vw,2.25rem)] font-black leading-tight text-[rgb(var(--ink))]">
                <a class="headline-link" href="{{ story.url }}">
                  <span class="story-proof-mark">
                    <img class="proof-mark story-proof-mark__icon" data-proof-mark data-proof-mark-day="{{ proofMarkDaySrc }}" data-proof-mark-night="{{ proofMarkNightSrc }}" data-proof-mark-print="{{ proofMarkPrintSrc }}" src="{{ proofMarkDaySrc }}" alt="" />
                  </span>
                  {{ story.data.title }}
                </a>
              </h3>
              <p class="mt-3 font-serif text-base leading-relaxed text-[rgb(var(--ink-soft))]">
                {{ story.data.description }}
              </p>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}

  <section class="space-y-6">
    <div class="flex items-end justify-between border-b border-[rgb(var(--rule-strong))] pb-3">
      <h2 class="font-display text-3xl font-black tracking-tight text-[rgb(var(--ink))]">How the reporting works</h2>
      <p class="section-kicker">Method</p>
    </div>
    <div class="max-w-4xl space-y-4">
      <p class="font-serif text-[1.14rem] leading-relaxed text-[rgb(var(--ink-soft))]">
        Each story starts with records, filings, and source documents. The writing states what happened, who acted, and what the record supports.
      </p>
      <p class="font-serif text-[1.14rem] leading-relaxed text-[rgb(var(--ink-soft))]">
        Every story opens with a Proof Card. The article that follows shows the reporting behind it.
      </p>
      <p class="font-serif text-[1.14rem] leading-relaxed text-[rgb(var(--ink-soft))]">
        The finding, the documents, and the reporting live in the same place. Each story keeps a permanent URL, a desk label, and an archive path so readers can search it, cite it, and revisit it.
      </p>
    </div>
  </section>

  {% if collections.authorProfiles | length %}
    <section class="space-y-6">
      <div class="flex items-end justify-between border-b border-[rgb(var(--rule-strong))] pb-3">
        <h2 class="font-display text-3xl font-black tracking-tight text-[rgb(var(--ink))]">Newsroom</h2>
        <p class="section-kicker">Newsroom</p>
      </div>
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {% for reporter in collections.authorProfiles %}
          {% set reporterStories = collections.article | articlesByAuthor(reporter.fileSlug) %}
          <article class="author-card card-lift p-5">
            <div class="flex items-start gap-4">
              {% if reporter.data.headshot %}
                {% image reporter.data.headshot, reporter.data.name, "72px", "h-16 w-16 rounded-full object-cover" %}
              {% else %}
                <div class="author-avatar">{{ reporter.data.name | initials }}</div>
              {% endif %}
              <div>
                <h3 class="font-serif text-2xl font-black leading-tight text-[rgb(var(--ink))]">
                  <a class="headline-link" href="{{ reporter.url }}">{{ reporter.data.name }}</a>
                </h3>
                <p class="mt-1 font-ui text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--ink-muted))]">
                  {{ reporter.data.role }}
                </p>
              </div>
            </div>
            <p class="mt-4 font-serif text-sm leading-relaxed text-[rgb(var(--ink-soft))]">
              {{ reporter.data.short_bio }}
            </p>
            <div class="meta-row mt-5">
              <span>{{ reporterStories | length }} published</span>
            </div>
          </article>
        {% endfor %}
      </div>
    </section>
  {% endif %}
</div>
