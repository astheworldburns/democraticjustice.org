{# Token migration: arbitrary values replaced — Phase 1B #}
---
layout: layouts/base.njk
title: Democratic Justice
description: Latest investigative reporting with proof cards and source documents.
permalink: /
ogType: website
---
{% set proofEntries = collections.proofArticle %}
{% set featuredEntry = proofEntries[0] if proofEntries | length else null %}
{% set featuredArticle = featuredEntry.article if featuredEntry else null %}
{% set featuredProof = featuredEntry.proofCard if featuredEntry else null %}
{% set featuredAuthor = featuredArticle.data.author | getAuthor(collections.authorProfiles) if featuredArticle else null %}

<main id="main-content">

  {# ── Featured Investigation ── #}
  <section aria-labelledby="featured-heading" class="home-main-bento mb-16">
    <article class="card card--featured bento-8 bento-rows-2 home-main-bento__hero">
      <span class="card__tag">{{ featuredArticle.data.kicker | default("Investigation") }}</span>
      <h2 id="featured-heading" class="font-serif text-display-lg">
        <a href="{{ featuredArticle.url }}" class="text-ink hover:text-accent transition-colors">{{ featuredArticle.data.title }}</a>
      </h2>
      <p class="font-serif text-xl text-ink-secondary mt-4">{{ featuredProof.issueShort | default(featuredArticle.data.description) }}</p>
      {% set metaDesk = featuredArticle.data.kicker %}
      {% set metaAuthor = featuredAuthor.data.name %}
      {% set metaAuthorUrl = featuredAuthor.url %}
      {% set metaDate = featuredArticle.date %}
      {% set metaReadTime = featuredArticle.templateContent | readingMinutes %}
      <div class="mt-6">{% include "components/meta-row.njk" %}</div>
    </article>

    <div class="card bento-4 home-main-bento__proof">
      <h3 class="section-header__kicker">Proof Summary</h3>
      <dl class="space-y-2 font-mono text-sm mt-3">
        <div class="flex justify-between"><dt class="text-ink-muted">Axioms</dt><dd class="font-semibold">{{ featuredProof.axiomCount }}</dd></div>
        <div class="flex justify-between"><dt class="text-ink-muted">Logic steps</dt><dd class="font-semibold">{{ featuredProof.logicCount }}</dd></div>
        <div class="flex justify-between"><dt class="text-ink-muted">Documents</dt><dd class="font-semibold">{{ featuredProof.sourceDocumentCount }}</dd></div>
      </dl>
      {% if featuredProof.conclusionShort %}
        <p class="mt-4 text-sm text-ink-secondary font-serif italic">{{ featuredProof.conclusionShort }}</p>
      {% endif %}
      <a href="{{ featuredArticle.url }}#proof-card" class="button-link-muted mt-5 w-full">Inspect proof chain</a>
    </div>

    <div class="card bento-4 home-main-bento__desks">
      <h3 class="section-header__kicker">Desks</h3>
      <ul class="space-y-2 mt-3">
        {% for desk in collections.editorialDesks %}
          <li class="flex justify-between items-center">
            <a href="/categories/{{ desk.slug }}/" class="font-mono text-sm text-accent hover:underline uppercase tracking-wide">{{ desk.label }}</a>
            <span class="font-mono text-xs text-ink-muted">{{ desk.count }}</span>
          </li>
        {% endfor %}
      </ul>
    </div>
  </section>

  {# ── All Investigations ── #}
  <section aria-labelledby="investigations-heading" class="mb-16">
    {% set sectionKicker = "Archive" %}
    {% set sectionTitle = "Investigations" %}
    {% set sectionId = "investigations-heading" %}
    {% include "components/section-header.njk" %}
    <div class="bento-grid">
      {% for entry in proofEntries %}
        {% set story = entry.article %}
        {% set proof = entry.proofCard %}
        {% set storyAuthor = story.data.author | getAuthor(collections.authorProfiles) %}
        <article class="card bento-4 {% if loop.index0 == 0 %}bento-8 bento-rows-2{% endif %}">
          <span class="card__tag">{{ story.data.kicker }}</span>
          <h3 class="font-serif {% if loop.index0 == 0 %}text-3xl{% else %}text-xl{% endif %} mt-1">
            <a href="{{ story.url }}" class="text-ink hover:text-accent transition-colors">{{ story.data.title }}</a>
          </h3>
          <p class="text-sm text-ink-secondary mt-2 {% if loop.index0 > 0 %}line-clamp-2{% endif %}">{{ story.data.description }}</p>
          <div class="mt-3 flex flex-wrap gap-3 font-mono text-xs text-ink-muted">
            <span>{{ proof.axiomCount }} axioms</span>
            <span>{{ proof.logicCount }} logic</span>
            <span>{{ proof.sourceDocumentCount }} docs</span>
          </div>
          {% set metaDesk = null %}{% set metaAuthor = storyAuthor.data.name %}{% set metaAuthorUrl = storyAuthor.url %}{% set metaDate = story.date %}{% set metaReadTime = null %}
          <div class="mt-3">{% include "components/meta-row.njk" %}</div>
        </article>
      {% endfor %}
    </div>
  </section>

  {# ── Staff ── #}
  <section aria-labelledby="staff-heading" class="mb-16">
    {% set sectionKicker = "Newsroom" %}
    {% set sectionTitle = "Staff" %}
    {% set sectionId = "staff-heading" %}
    {% include "components/section-header.njk" %}
    <div class="bento-grid">
      {% for reporter in collections.authorProfiles %}
        {% set reporterStories = collections.article | articlesByAuthor(reporter.fileSlug) %}
        <article class="card bento-4">
          {% if reporter.data.headshot %}
            <img src="{{ reporter.data.headshot }}" alt="Photo of {{ reporter.data.name }}" class="w-16 h-16 rounded-full object-cover mb-3" width="64" height="64" loading="lazy" decoding="async">
          {% endif %}
          <h3 class="font-serif text-lg"><a href="{{ reporter.url }}" class="text-ink hover:text-accent">{{ reporter.data.name }}</a></h3>
          <p class="font-mono text-xs text-ink-muted uppercase tracking-wide">{{ reporter.data.role }}</p>
          {% if reporter.data.short_bio %}<p class="text-sm text-ink-secondary mt-2">{{ reporter.data.short_bio }}</p>{% endif %}
          <p class="font-mono text-xs text-ink-muted mt-2">{{ reporterStories.length }} investigation{{ "s" if reporterStories.length != 1 }}</p>
        </article>
      {% endfor %}
    </div>
  </section>

</main>
