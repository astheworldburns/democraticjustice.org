---
layout: layouts/base.njk
title: Democratic Justice
description: Latest investigative reporting with proof cards and source documents.
permalink: /
ogType: website
---
{% set proofEntries = collections.proofArticle %}
{% set featuredEntry = proofEntries[0] if proofEntries | length else null %}
{% set featuredArticle = featuredEntry.article if featuredEntry else null %}
{% set featuredProof = featuredEntry.proofCard if featuredEntry else null %}
{% set featuredAuthor = featuredArticle.data.author | getAuthor(collections.authorProfiles) if featuredArticle else null %}

<div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">

  {# ═══ HERO ROW ═══ #}
  <div class="bento-grid mb-5">

    <article class="card card--featured bento-8 bento-rows-2">
      {% if featuredArticle.data.kicker %}
        <span class="font-mono text-xs uppercase tracking-wide text-ink-muted">{{ featuredArticle.data.kicker }}</span>
      {% endif %}
      <h2 class="font-serif text-display-md mt-2 leading-tight">
        <a href="{{ featuredArticle.url }}" class="text-ink hover:text-accent transition-colors no-underline">{{ featuredArticle.data.title }}</a>
      </h2>
      <p class="text-lg text-ink-secondary mt-4 leading-relaxed">{{ featuredArticle.data.description }}</p>
      <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-xs text-ink-muted uppercase tracking-wide">
        <time datetime="{{ featuredArticle.date | machineDate }}">{{ featuredArticle.date | displayDate }}</time>
        <span>·</span>
        {% if featuredAuthor %}<a href="{{ featuredAuthor.url }}" class="text-ink-secondary hover:text-accent no-underline">by {{ featuredAuthor.data.name }}</a><span>·</span>{% endif %}
        <span>{{ featuredArticle.templateContent | readingMinutes }} min read</span>
      </div>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="{{ featuredArticle.url }}" class="inline-block bg-ink text-surface font-mono text-sm uppercase tracking-wide px-5 py-2.5 rounded-squircle-sm hover:bg-accent transition-colors no-underline">Read Investigation</a>
        <a href="{{ featuredArticle.url }}#proof-card" class="inline-block border border-border text-ink-secondary font-mono text-sm uppercase tracking-wide px-5 py-2.5 rounded-squircle-sm hover:border-accent hover:text-accent transition-colors no-underline">Open Proof Card</a>
        <a href="{{ featuredArticle.url }}#source-documents" class="inline-block border border-border text-ink-secondary font-mono text-sm uppercase tracking-wide px-5 py-2.5 rounded-squircle-sm hover:border-accent hover:text-accent transition-colors no-underline">Source Documents</a>
      </div>
    </article>

    <div class="card bento-4">
      <span class="font-mono text-xs uppercase tracking-wide text-ink-muted">Proof Summary</span>
      <dl class="mt-4 space-y-4">
        <div class="flex items-center justify-between"><dt class="font-mono text-sm text-ink-muted">Axioms</dt><dd class="font-serif text-3xl font-bold text-ink">{{ featuredProof.axiomCount }}</dd></div>
        <div class="flex items-center justify-between"><dt class="font-mono text-sm text-ink-muted">Logic Steps</dt><dd class="font-serif text-3xl font-bold text-ink">{{ featuredProof.logicCount }}</dd></div>
        <div class="flex items-center justify-between"><dt class="font-mono text-sm text-ink-muted">Documents</dt><dd class="font-serif text-3xl font-bold text-ink">{{ featuredProof.sourceDocumentCount }}</dd></div>
      </dl>
    </div>

    <div class="card bento-4">
      <span class="font-mono text-xs uppercase tracking-wide text-ink-muted">Issue Under Proof</span>
      <p class="font-serif text-base text-ink leading-relaxed mt-3">{{ featuredProof.issueShort | default("—") }}</p>
      {% if featuredProof.conclusionShort %}
        <div class="mt-4 pt-4 border-t border-border-subtle">
          <span class="font-mono text-xs text-ink-muted uppercase tracking-wide">Where the Reporting Lands</span>
          <p class="font-serif text-sm text-ink-secondary italic mt-2 leading-relaxed">{{ featuredProof.conclusionShort }}</p>
        </div>
      {% endif %}
    </div>

  </div>

  {# ═══ INFO ROW ═══ #}
  <div class="bento-grid mb-16">

    <div class="card bento-4">
      <span class="font-mono text-xs uppercase tracking-wide text-ink-muted">Proof-First Method</span>
      <p class="text-sm text-ink-secondary mt-3 mb-4">Read the case before the narrative.</p>
      <dl class="space-y-3">
        <div><dt class="font-mono text-xs text-accent uppercase tracking-wide font-semibold">Proof Card</dt><dd class="text-sm text-ink-secondary mt-0.5">Issue, axioms, and inferences first.</dd></div>
        <div><dt class="font-mono text-xs text-accent uppercase tracking-wide font-semibold">Source Records</dt><dd class="text-sm text-ink-secondary mt-0.5">Every claim links to a document page.</dd></div>
        <div><dt class="font-mono text-xs text-accent uppercase tracking-wide font-semibold">Reported Story</dt><dd class="text-sm text-ink-secondary mt-0.5">Context follows evidence.</dd></div>
      </dl>
    </div>

    <div class="card bento-4">
      <span class="font-mono text-xs uppercase tracking-wide text-ink-muted">Desks</span>
      <p class="text-sm text-ink-secondary mt-3 mb-4">Browse by desk.</p>
      <ul class="space-y-3">
        {% for desk in collections.editorialDesks %}
          <li class="flex items-center justify-between">
            <a href="/categories/{{ desk.slug }}/" class="font-mono text-sm text-ink hover:text-accent transition-colors no-underline font-semibold">{{ desk.label }}</a>
            <span class="font-mono text-xs text-ink-muted bg-surface px-2 py-0.5 rounded-full">{{ desk.count }} {{ "report" if desk.count == 1 else "reports" }}</span>
          </li>
        {% endfor %}
      </ul>
    </div>

    <div class="card bento-4">
      <div class="flex items-center justify-between mb-4">
        <span class="font-mono text-xs uppercase tracking-wide text-ink-muted">Newsroom</span>
        <a href="/staff/" class="font-mono text-xs text-accent hover:underline uppercase tracking-wide">Open Staff</a>
      </div>
      <ul class="space-y-4">
        {% for reporter in collections.authorProfiles %}
          {% set reporterStories = collections.article | articlesByAuthor(reporter.fileSlug) %}
          <li class="flex items-center gap-3">
            {% if reporter.data.headshot %}
              <img src="{{ reporter.data.headshot }}" alt="Photo of {{ reporter.data.name }}" class="w-10 h-10 rounded-full object-cover flex-shrink-0" width="40" height="40" loading="lazy" decoding="async">
            {% else %}
              <div class="w-10 h-10 rounded-full bg-surface flex-shrink-0 flex items-center justify-center font-mono text-xs text-ink-muted">{{ reporter.data.name | initials }}</div>
            {% endif %}
            <div class="min-w-0">
              <a href="{{ reporter.url }}" class="font-serif text-sm text-ink hover:text-accent no-underline font-semibold block truncate">{{ reporter.data.name }}</a>
              <span class="font-mono text-xs text-ink-muted">{{ reporter.data.role }}{% if reporterStories.length %} · {{ reporterStories.length }} {{ "investigation" if reporterStories.length == 1 else "investigations" }}{% endif %}</span>
            </div>
          </li>
        {% endfor %}
      </ul>
    </div>

  </div>

</div>
