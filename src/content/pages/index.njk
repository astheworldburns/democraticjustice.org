---
layout: layouts/base.njk
title: Democratic Justice
description: Latest investigative reporting with proof cards and source documents.
permalink: /
ogType: website
---
{% set proofEntries = collections.proofArticle %}
{% set featuredEntry = proofEntries[0] if proofEntries | length else null %}
{% set featuredArticle = featuredEntry.article if featuredEntry else null %}
{% set featuredProof = featuredEntry.proofCard if featuredEntry else null %}
{% set featuredAuthor = featuredArticle.data.author | getAuthor(collections.authorProfiles) if featuredArticle else null %}
{% set evidenceDocuments = collections.primarySourceDocument or [] %}

<style>
  .hp-doc-thumb {
    width: 100% !important;
    height: 5.5rem !important;
    overflow: hidden !important;
    background: var(--color-bg-page) !important;
  }
  .hp-doc-thumb img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: top !important;
    opacity: 0.85;
    transition: opacity 0.15s ease;
  }
  a:hover .hp-doc-thumb img {
    opacity: 1;
  }
  .hp-pdf-badge {
    background: var(--color-badge-pdf) !important;
    border: 1px solid var(--color-border) !important;
    width: 3rem !important;
    height: 3.5rem !important;
    border-radius: 0.375rem !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    flex-shrink: 0 !important;
  }
  .hp-pdf-badge-label {
    color: var(--color-accent) !important;
    font-weight: 700 !important;
  }
  [data-theme="dark"] .hp-pdf-badge {
    background: var(--color-bg-proof) !important;
    border-color: var(--color-border-on-proof) !important;
  }
  [data-theme="dark"] .hp-pdf-badge-label {
    color: var(--color-accent-on-proof) !important;
  }
</style>

<div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">

  {# ═══ HERO ROW ═══ #}
  <div class="bento-grid mb-5">

    <article class="card card--featured bento-8 bento-rows-2">
      {% if featuredArticle.data.kicker %}
        <span class="font-mono text-xs uppercase tracking-wide text-ink-muted">{{ featuredArticle.data.kicker }}</span>
      {% endif %}
      <h2 class="font-serif text-display-md mt-2 leading-tight">
        <a href="{{ featuredArticle.url }}" class="text-ink hover:text-accent transition-colors no-underline">{{ featuredArticle.data.title }}</a>
      </h2>
      <p class="text-lg text-ink-secondary mt-4 leading-relaxed">{{ featuredArticle.data.description }}</p>
      <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-xs text-ink-muted uppercase tracking-wide">
        <time datetime="{{ featuredArticle.date | machineDate }}">{{ featuredArticle.date | displayDate }}</time>
        <span>·</span>
        {% if featuredAuthor %}<a href="{{ featuredAuthor.url }}" class="text-ink-secondary hover:text-accent no-underline">by {{ featuredAuthor.data.name }}</a><span>·</span>{% endif %}
        <span>{{ featuredArticle.templateContent | readingMinutes }} min read</span>
      </div>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="{{ featuredArticle.url }}" class="inline-block bg-ink text-surface font-mono text-sm uppercase tracking-wide px-5 py-2.5 rounded-squircle-sm hover:bg-accent transition-colors no-underline">Read Investigation</a>
        <a href="{{ featuredArticle.url }}#proof-card" class="inline-block border border-border text-ink-secondary font-mono text-sm uppercase tracking-wide px-5 py-2.5 rounded-squircle-sm hover:border-accent hover:text-accent transition-colors no-underline">Open Proof Card</a>
        <a href="{{ featuredArticle.url }}#source-documents" class="inline-block border border-border text-ink-secondary font-mono text-sm uppercase tracking-wide px-5 py-2.5 rounded-squircle-sm hover:border-accent hover:text-accent transition-colors no-underline">Source Documents</a>
      </div>
      <div class="mt-8 pt-6 border-t border-border-subtle">
        <span class="font-mono text-xs uppercase tracking-wide text-ink-muted block mb-3">Preview</span>
        <p class="font-serif text-base text-ink-secondary leading-relaxed">
          {{ featuredArticle.templateContent | excerptText(350) }}
        </p>
      </div>
    </article>

    <div class="card hp-card bento-4 hp-span-4 bento-rows-2 hp-rows-2" style="display:flex;flex-direction:column">

      {# ── Evidence Room: global document archive ── #}
      <div>
        <span class="font-mono text-xs uppercase tracking-wide text-accent">The Evidence Room</span>
        <p class="text-sm text-ink-muted mt-1">{{ evidenceDocuments.length }} source {{ "document" if evidenceDocuments.length == 1 else "documents" }} on file.</p>

        {% if evidenceDocuments.length %}
          <ul class="mt-4 space-y-3">
            {% for doc in evidenceDocuments %}
              <li>
                <a href="{{ doc.url }}" class="group block no-underline rounded-squircle-sm border border-border-subtle overflow-hidden hover:border-accent transition-colors">

                  {# Thumbnail or type badge #}
                  {% if doc.data.preview_image %}
                    <div class="hp-doc-thumb">
                      <img src="{{ doc.data.preview_image }}"
                           alt="Preview of {{ doc.data.title }}"
                           loading="lazy" decoding="async">
                    </div>
                  {% elif doc.data.file_type == "pdf" %}
                    <div class="w-full h-24 bg-surface flex items-center gap-3 px-4">
                      <div class="hp-pdf-badge">
                        <span class="hp-pdf-badge-label font-mono text-xs uppercase">PDF</span>
                      </div>
                      <div class="min-w-0">
                        <span class="font-mono text-xs text-ink-muted block">Portable Document</span>
                        <span class="font-mono text-xs text-ink-muted block mt-0.5">Preview processing</span>
                      </div>
                    </div>
                  {% elif doc.data.video_url %}
                    <div class="w-full h-12 bg-surface flex items-center justify-center">
                      <span class="font-mono text-xs text-ink-muted uppercase tracking-wide">VIDEO</span>
                    </div>
                  {% else %}
                    <div class="w-full h-12 bg-surface flex items-center justify-center">
                      <span class="font-mono text-xs text-ink-muted uppercase tracking-wide">{{ doc.data.file_type | default("doc") | upper }}</span>
                    </div>
                  {% endif %}

                  {# Document info #}
                  <div class="px-3 py-2">
                    <span class="text-sm text-ink font-semibold leading-snug block group-hover:text-accent transition-colors">
                      {{ doc.data.title }}
                    </span>
                    <div class="flex items-center gap-2 mt-1 flex-wrap">
                      {% if doc.data.obtained %}
                        <span class="font-mono text-xs text-ink-muted">{{ doc.data.obtained | displayDate }}</span>
                      {% endif %}
                      {% if doc.data.source_method %}
                        <span class="font-mono text-xs text-ink-muted">· {{ doc.data.source_method }}</span>
                      {% endif %}
                    </div>
                  </div>

                </a>
              </li>
            {% endfor %}
          </ul>
          <a href="/documents/" class="inline-block mt-4 font-mono text-xs text-accent hover:underline uppercase tracking-wide">Full Document Archive →</a>
        {% else %}
          <p class="text-sm text-ink-muted mt-4 italic">Documents published with each investigation.</p>
        {% endif %}
      </div>

      {# Spacer #}
      <div class="flex-1 min-h-4"></div>

      {# ── Subscribe CTA ── #}
      <div class="pt-5 mt-5 border-t border-border-subtle">
        <span class="font-mono text-xs uppercase tracking-wide text-accent">Stay on the Case</span>
        <p class="text-sm text-ink-secondary mt-2 leading-relaxed">
          Get investigations delivered. No algorithms. No feeds. Just proof.
        </p>
        <form
          action="https://buttondown.com/api/emails/embed-subscribe/democraticjustice"
          method="post"
          class="embeddable-buttondown-form mt-4"
        >
          <label for="bd-email" class="sr-only">Enter your email</label>
          <input type="email" name="email" id="bd-email" required placeholder="Enter your email" class="w-full border border-border rounded-squircle-sm px-3 py-2 text-sm text-ink bg-surface" />
          <input type="submit" value="Subscribe" class="mt-3 inline-flex items-center justify-center w-full bg-ink text-surface font-mono text-sm uppercase tracking-wide px-5 py-2.5 rounded-squircle-sm hover:bg-accent transition-colors cursor-pointer" />
          <p class="mt-2 text-xs text-ink-muted">
            <a href="https://buttondown.com/refer/democraticjustice" target="_blank" rel="noopener noreferrer" class="text-ink-muted hover:text-accent">
              Powered by Buttondown.
            </a>
          </p>
        </form>
      </div>

    </div>

  </div>

  {# ═══ INFO ROW ═══ #}
  <div class="bento-grid mb-16">

    <div class="card bento-4">
      <span class="font-mono text-xs uppercase tracking-wide text-ink-muted">Proof-First Method</span>
      <p class="text-sm text-ink-secondary mt-3 mb-4">Read the case before the narrative.</p>
      <dl class="space-y-3">
        <div><dt class="font-mono text-xs text-accent uppercase tracking-wide font-semibold">Proof Card</dt><dd class="text-sm text-ink-secondary mt-0.5">Issue, axioms, and inferences first.</dd></div>
        <div><dt class="font-mono text-xs text-accent uppercase tracking-wide font-semibold">Source Records</dt><dd class="text-sm text-ink-secondary mt-0.5">Every claim links to a document page.</dd></div>
        <div><dt class="font-mono text-xs text-accent uppercase tracking-wide font-semibold">Reported Story</dt><dd class="text-sm text-ink-secondary mt-0.5">Context follows evidence.</dd></div>
      </dl>
    </div>

    <div class="card bento-4">
      <span class="font-mono text-xs uppercase tracking-wide text-ink-muted">Desks</span>
      <p class="text-sm text-ink-secondary mt-3 mb-4">Browse by desk.</p>
      <ul class="space-y-3">
        {% for desk in collections.editorialDesks %}
          <li class="flex items-center justify-between">
            <a href="/categories/{{ desk.slug }}/" class="font-mono text-sm text-ink hover:text-accent transition-colors no-underline font-semibold">{{ desk.label }}</a>
            <span class="font-mono text-xs text-ink-muted bg-surface px-2 py-0.5 rounded-full">{{ desk.count }} {{ "report" if desk.count == 1 else "reports" }}</span>
          </li>
        {% endfor %}
      </ul>
    </div>

    <div class="card bento-4">
      <div class="flex items-center justify-between mb-4">
        <span class="font-mono text-xs uppercase tracking-wide text-ink-muted">Newsroom</span>
        <a href="/staff/" class="font-mono text-xs text-accent hover:underline uppercase tracking-wide">Open Staff</a>
      </div>
      <ul class="space-y-4">
        {% for reporter in collections.authorProfiles %}
          {% set reporterStories = collections.article | articlesByAuthor(reporter.fileSlug) %}
          <li class="flex items-center gap-3">
            {% if reporter.data.headshot %}
              <img src="{{ reporter.data.headshot }}" alt="Photo of {{ reporter.data.name }}" class="w-10 h-10 rounded-full object-cover flex-shrink-0" width="40" height="40" loading="lazy" decoding="async">
            {% else %}
              <div class="w-10 h-10 rounded-full bg-surface flex-shrink-0 flex items-center justify-center font-mono text-xs text-ink-muted">{{ reporter.data.name | initials }}</div>
            {% endif %}
            <div class="min-w-0">
              <a href="{{ reporter.url }}" class="font-serif text-sm text-ink hover:text-accent no-underline font-semibold block truncate">{{ reporter.data.name }}</a>
              <span class="font-mono text-xs text-ink-muted">{{ reporter.data.role }}{% if reporterStories.length %} · {{ reporterStories.length }} {{ "investigation" if reporterStories.length == 1 else "investigations" }}{% endif %}</span>
            </div>
          </li>
        {% endfor %}
      </ul>
    </div>

  </div>

</div>
