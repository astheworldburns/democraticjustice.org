---
layout: layouts/base.njk
title: Democratic Justice
description: Latest investigative reporting with proof cards and source documents.
permalink: /
ogType: website
---
{% set proofEntries = collections.proofArticle %}
{% set featuredEntry = proofEntries[0] if proofEntries | length else null %}
{% set featuredArticle = featuredEntry.article if featuredEntry else null %}
{% set featuredProof = featuredEntry.proofCard if featuredEntry else null %}
{% set featuredAuthor = featuredArticle.data.author | getAuthor(collections.authorProfiles) if featuredArticle else null %}

<div class="home-shell home-shell--news" data-pagefind-body>
  {% if featuredArticle and featuredProof %}
    <section class="home-news-lead math-grid-front">
      <article class="home-news-lead__main math-rank-major" data-math-rank="major">
        <div class="home-news-lead__editorial">
          <p class="section-kicker">Latest investigation</p>
          <h1 class="home-news-lead__title">
            <a class="headline-link" href="{{ featuredArticle.url }}">{{ featuredArticle.data.title }}</a>
          </h1>
          <div class="meta-row mt-3">
            <span>{{ featuredArticle.date | displayDate }}</span>
            <span class="meta-divider">By {% if featuredAuthor %}<a class="headline-link" href="{{ featuredAuthor.url }}">{{ featuredAuthor.data.name }}</a>{% else %}{{ site.name }}{% endif %}</span>
            <span class="meta-divider">{{ featuredArticle.templateContent | readingMinutes }} min read</span>
          </div>
          <p class="home-news-lead__description">{{ featuredArticle.data.description }}</p>

          <div class="home-actions mt-5">
            <a class="button-link" href="{{ featuredArticle.url }}" data-haptic data-haptic="confirm">Read investigation</a>
            <a class="button-link-muted" href="{{ featuredArticle.url }}" data-haptic data-haptic="medium">Open proof card</a>
            <a class="button-link-muted" href="/documents/" data-haptic>Source documents</a>
          </div>
        </div>

        <div class="home-news-lead__evidence">
          <div class="home-proof-metrics">
            <span>{{ featuredProof.axiomCount }} axioms</span>
            <span>{{ featuredProof.logicCount }} inferences</span>
            <span>{{ featuredProof.sourceDocumentCount }} documents</span>
          </div>
          <div class="home-news-lead__proof">
            <section class="home-news-lead__proof-tile">
              <p class="home-proof-block__label">Issue under proof</p>
              <p class="home-proof-block__text">{{ featuredProof.issueShort }}</p>
            </section>
            <section class="home-news-lead__proof-tile">
              <p class="home-proof-block__label">Where the reporting lands</p>
              <p class="home-proof-block__text">{{ featuredProof.conclusionShort }}</p>
            </section>
          </div>
        </div>
      </article>

      <aside class="home-news-lead__side">
        <section class="home-news-card math-rank-medium" data-math-rank="medium">
          <p class="section-kicker">Proof-first method</p>
          <h2 class="home-news-card__title">Read the case before the narrative.</h2>
          <ol class="home-news-order">
            <li><strong>Proof card</strong><span>Issue, axioms, and inferences first.</span></li>
            <li><strong>Source records</strong><span>Every claim links to a document page.</span></li>
            <li><strong>Reported story</strong><span>Context follows evidence.</span></li>
          </ol>
        </section>

        {% if collections.editorialDesks | length %}
          <section class="home-news-card math-rank-small" data-math-rank="small">
            <p class="section-kicker">Desks</p>
            <h2 class="home-news-card__title">Browse by desk.</h2>
            <div class="home-news-list">
              {% for desk in collections.editorialDesks %}
                <a class="home-news-list__item" href="/category/{{ desk.slug }}/">
                  <strong>{{ desk.label }}</strong>
                  <span>{{ desk.count }} report{% if desk.count != 1 %}s{% endif %}</span>
                </a>
              {% endfor %}
            </div>
          </section>
        {% endif %}
      </aside>
    </section>
  {% endif %}

  {% if proofEntries | length > 1 %}
    <section class="space-y-4 home-section-latest">
      <div class="flex items-end justify-between border-b border-[rgba(var(--rule-strong),0.82)] pb-3">
        <div>
          <p class="section-kicker">More reporting</p>
          <h2 class="homepage-section-heading">Recent investigations</h2>
        </div>
        <a class="button-link-muted" href="/archives/">Open archive</a>
      </div>

      <div class="home-story-grid">
        {% for entry in proofEntries %}
          {% if not loop.first and loop.index <= 7 %}
            {% set story = entry.article %}
            {% set proof = entry.proofCard %}
            {% set storyAuthor = story.data.author | getAuthor(collections.authorProfiles) %}
            {% set storyRankClass = "math-rank-major" if loop.index == 2 else ("math-rank-medium" if loop.index < 5 else "math-rank-small") %}
            {% set storyRank = "major" if loop.index == 2 else ("medium" if loop.index < 5 else "small") %}
            <article class="home-story-card home-story-card--bento {{ storyRankClass }}" data-math-rank="{{ storyRank }}">
              <p class="section-kicker">{{ story.data.kicker or "Investigation" }}</p>
              <h3 class="home-story-card__title"><a class="headline-link" href="{{ story.url }}">{{ story.data.title }}</a></h3>
              <div class="meta-row">
                <span>{{ story.date | displayDate }}</span>
                {% if storyAuthor %}<span class="meta-divider"><a class="headline-link" href="{{ storyAuthor.url }}">{{ storyAuthor.data.name }}</a></span>{% endif %}
              </div>
              <p class="home-story-card__description">{{ story.data.description }}</p>
              <div class="home-proof-metrics">
                <span>{{ proof.axiomCount }} axioms</span>
                <span>{{ proof.logicCount }} inferences</span>
                <span>{{ proof.sourceDocumentCount }} docs</span>
              </div>
              <div class="home-actions mt-2">
                <a class="button-link" href="{{ story.url }}" data-haptic>Read</a>
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {% if collections.authorProfiles | length %}
    <section class="space-y-4">
      <div class="flex items-end justify-between border-b border-[rgba(var(--rule-strong),0.82)] pb-3">
        <div>
          <p class="section-kicker">Newsroom</p>
          <h2 class="homepage-section-heading">Bylines</h2>
        </div>
        <a class="button-link-muted" href="/staff/">Open staff</a>
      </div>
      <div class="staff-bento-grid">
        {% for reporter in collections.authorProfiles %}
          {% set reporterStories = collections.article | articlesByAuthor(reporter.fileSlug) %}
          {% set staffRankClass = "math-rank-major" if loop.first else ("math-rank-medium" if loop.index <= 3 else "math-rank-small") %}
          {% set staffRank = "major" if loop.first else ("medium" if loop.index <= 3 else "small") %}
          <article class="author-card card-lift staff-bento-card p-4 {{ staffRankClass }}" data-math-rank="{{ staffRank }}">
            <div class="flex items-start gap-3">
              {% if reporter.data.headshot %}
                {% image reporter.data.headshot, reporter.data.name, "72px", "h-16 w-16 rounded-full object-cover" %}
              {% else %}
                <div class="author-avatar">{{ reporter.data.name | initials }}</div>
              {% endif %}
              <div>
                <h3 class="font-serif text-[1.4rem] font-semibold leading-tight text-[rgb(var(--ink))]">
                  <a class="headline-link" href="{{ reporter.url }}">{{ reporter.data.name }}</a>
                </h3>
                <p class="mt-1 font-mono text-[0.58rem] uppercase tracking-[0.1em] text-[rgb(var(--ink-muted))]">{{ reporter.data.role }}</p>
              </div>
            </div>
            <p class="mt-3 font-serif text-[0.92rem] leading-relaxed text-[rgb(var(--ink-soft))]">{{ reporter.data.short_bio }}</p>
            <div class="meta-row mt-4"><span>{{ reporterStories | length }} published</span></div>
          </article>
        {% endfor %}
      </div>
    </section>
  {% endif %}
</div>
