---
permalink: /news-sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:news="http://www.google.com/schemas/sitemap-news/0.9">
{% set nowMs = buildDate.getTime() %}
{% for article in collections.article %}
  {% set ageMs = nowMs - article.date.getTime() %}
  {% if ageMs >= 0 and ageMs <= (48 * 60 * 60 * 1000) %}
  <url>
    <loc>{{ site.url }}{{ article.url }}</loc>
    <news:news>
      <news:publication>
        <news:name>Democratic Justice</news:name>
        <news:language>en</news:language>
      </news:publication>
      <news:publication_date>{{ article.date | machineDate }}</news:publication_date>
      <news:title>{{ article.data.title | escape }}</news:title>
    </news:news>
  </url>
  {% endif %}
{% endfor %}
</urlset>
