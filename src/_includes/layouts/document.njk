---
layout: layouts/base.njk
ogType: website
---
<article class="document-shell document-shell--bento" data-pagefind-body>
  <div class="sr-only" aria-hidden="true">
    <span data-pagefind-meta="type">Source document</span>
    <span data-pagefind-meta="source_method">{{ source_method }}</span>
    <span data-pagefind-meta="obtained">{{ obtained }}</span>
  </div>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Dataset",
      "name": "{{ title | replace('"', '\\"') }}",
      "description": "{{ description | replace('"', '\\"') }}",
      "url": "{{ page.url | absoluteUrl(site.url) }}",
      "datePublished": "{{ obtained | machineDate }}",
      "creator": { "@id": "{{ site.url }}/#organization" },
      "distribution": {
        "@type": "DataDownload",
        "contentUrl": "{{ file_url | absoluteUrl(site.url) }}",
        "encodingFormat": "{{ file_type }}"
      }
    }
  </script>

  <header class="document-shell__header">
    <p class="section-kicker">Source document</p>
    <h1 class="document-shell__title">{{ title }}</h1>
    {% if description %}
      <p class="document-shell__description">{{ description }}</p>
    {% endif %}
    <div class="document-shell__actions">
      <a class="button-link" href="{{ file_url }}" target="_blank" rel="noreferrer">Open file</a>
      <a class="button-link-muted" href="{{ file_url }}" download>Download</a>
    </div>
  </header>

  <div class="document-shell__grid">
    <section class="document-shell__primary">
      <div class="document-preview">
        {% if file_type == "image" %}
          <img class="document-preview__image" src="{{ file_url }}" alt="{{ title }}" loading="lazy" />
        {% elseif file_type == "pdf" %}
          <iframe class="document-preview__frame" src="{{ file_url }}#view=FitH" title="{{ title }}"></iframe>
        {% else %}
          <div class="document-preview__fallback">
            <p class="section-kicker">Preview unavailable</p>
            <p class="mt-3 font-serif text-base leading-relaxed text-[rgb(var(--ink-soft))]">Open the file directly from the link above.</p>
          </div>
        {% endif %}
      </div>
    </section>

    <aside class="document-shell__sidebar">
      <section class="document-meta">
        <p class="section-kicker">Document record</p>
        <dl class="document-meta__list">
          <div class="document-meta__item">
            <dt>Obtained</dt>
            <dd>{{ obtained | displayDate }}</dd>
          </div>
          <div class="document-meta__item">
            <dt>Source method</dt>
            <dd>{{ source_method }}</dd>
          </div>
          <div class="document-meta__item">
            <dt>File URL</dt>
            <dd><a class="headline-link break-all" href="{{ file_url }}">{{ file_url }}</a></dd>
          </div>
        </dl>
        <p class="provenance-note">C2PA: no manifest attached to this source file.</p>
      </section>
    </aside>
  </div>
</article>
