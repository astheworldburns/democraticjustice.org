---
layout: layouts/base.njk
---
<article class="mx-auto max-w-4xl">
  <header class="border-b-2 border-stone-900 pb-8">
    <p class="font-ui text-xs font-semibold uppercase tracking-kicker text-stone-600">
      Investigative Report
    </p>
    <h1 class="mt-3 max-w-4xl font-display text-4xl font-black leading-tight tracking-tight text-stone-950 md:text-6xl">
      {{ title }}
    </h1>
    {% if description %}
      <p class="mt-5 max-w-3xl border-b-2 border-stone-900 pb-4 font-serif text-xl italic leading-relaxed text-stone-600">
        {{ description }}
      </p>
    {% endif %}
    <div class="mt-5 flex flex-wrap gap-x-4 gap-y-2 font-ui text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">
      <span>By {{ author or site.author }}</span>
      <span>{{ date | displayDate }}</span>
    </div>
    {% if tags and tags.length > 1 %}
      <div class="mt-4 flex flex-wrap gap-3">
        {% for tag in tags %}
          {% if tag != "article" %}
            <a class="border border-stone-300 px-3 py-1 font-ui text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-stone-600 hover:border-stone-900 hover:text-stone-950" href="/category/{{ tag | slugifyTag }}/">
              {{ tag | tagLabel }}
            </a>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </header>

  {% if featured_image %}
    <figure class="my-8 border border-stone-300 bg-stone-100 p-2">
      {% image featured_image, title, "(min-width: 1024px) 1200px, 100vw", "w-full grayscale" %}
    </figure>
  {% endif %}

  <div class="article-prose mx-auto mt-10 max-w-none prose prose-lg prose-stone prose-headings:font-serif prose-p:font-serif">
    {{ content | safe }}
  </div>
</article>
