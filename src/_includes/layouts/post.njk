---
layout: layouts/base.njk
ogType: article
---
{% set authorProfile = author | getAuthor(collections.authorProfiles) %}
{% set articleHtml = content | withHeadingIds | safe %}
{% set tocItems = content | withHeadingIds | extractHeadings %}
{% set relatedStories = collections.article | relatedArticles(page, tags, 3) %}

{% if proofCard %}
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"{{ site.url }}"},{"@type":"ListItem","position":2,"name":"{{ kicker | default('Investigations') }}","item":"{{ site.url }}/categories/{{ kicker | slugifyTag }}/"},{"@type":"ListItem","position":3,"name":"{{ title }}"}]}
</script>
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"ClaimReview","url":"{{ site.url }}{{ page.url }}","claimReviewed":"{{ proofCard.issue | replace('"', '\\"') }}","author":{"@type":"NewsMediaOrganization","name":"{{ site.name }}","url":"{{ site.url }}"},"reviewRating":{"@type":"Rating","ratingValue":"{{ proofCard.axiomCount }}","bestRating":"{{ proofCard.axiomCount }}","ratingExplanation":"Supported by {{ proofCard.axiomCount }} documented axioms and {{ proofCard.sourceDocumentCount }} source documents"},"itemReviewed":{"@type":"Claim","appearance":[{% for doc in proofCard.sourceDocuments %}{"@type":"CreativeWork","url":"{{ site.url }}{{ doc.url }}","name":"{{ doc.data.title | replace('"', '\\"') }}"}{% if not loop.last %},{% endif %}{% endfor %}]}}
</script>
{% endif %}

<div class="sr-only" aria-hidden="true">
  <span data-pagefind-meta="type">Article</span>
  {% if authorProfile %}
    <span data-pagefind-meta="author">{{ authorProfile.data.name }}</span>
    <span data-pagefind-filter="author">{{ authorProfile.data.name }}</span>
  {% endif %}
  <span data-pagefind-filter="year">{{ date | displayYear }}</span>
  {% for tag in tags %}
    {% if tag != "article" %}
      <span data-pagefind-filter="desk">{{ tag | tagLabel }}</span>
    {% endif %}
  {% endfor %}
</div>

{# Sticky proof navigator #}
{% if proofCard %}
<nav class="proof-nav" aria-label="Investigation sections">
  <ol class="proof-nav__list">
    <li><a href="#proof-card" class="proof-nav__link" data-section="proof-card" aria-current="true">Proof Card</a></li>
    <li><a href="#source-documents" class="proof-nav__link" data-section="source-documents">Source Documents</a></li>
    <li><a href="#narrative" class="proof-nav__link" data-section="narrative">Narrative</a></li>
  </ol>
</nav>
{% endif %}

<main id="main-content" data-pagefind-body>

  {# Section 1: Proof Card #}
  {% if proofCard %}
    {% include "components/proof-card.njk" %}
  {% endif %}

  {# Section 2: Source Documents #}
  {% if proofCard and proofCard.sourceDocuments.length %}
  <section id="source-documents" aria-labelledby="source-docs-heading" class="mb-16">
    {% set sectionKicker = "02" %}{% set sectionTitle = "Source Documents" %}{% set sectionId = "source-docs-heading" %}
    {% include "components/section-header.njk" %}
    <div class="bento-grid">
      {% for doc in proofCard.sourceDocuments %}
        {% set docTitle = doc.data.title %}{% set docDescription = doc.data.description %}{% set docUrl = doc.url %}{% set docFile = doc.data.file %}{% set docFileType = doc.data.file_type %}{% set docObtained = doc.data.obtained %}{% set docSourceMethod = doc.data.source_method %}
        <div class="bento-6">{% include "components/document-card.njk" %}</div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# Section 3: Reported Narrative #}
  <section id="narrative" aria-labelledby="narrative-heading" class="mb-16">
    <h2 id="narrative-heading" class="sr-only">Reported Narrative</h2>
    {% if tocItems.length > 2 %}
      <aside class="mb-8 p-4 border border-border-subtle rounded-squircle max-w-2xl mx-auto" aria-label="Table of contents">
        <h3 class="font-mono text-xs uppercase tracking-widest text-ink-muted mb-3">Contents</h3>
        <ol class="space-y-1">{% for item in tocItems %}<li class="{{ 'ml-4' if item.level === 3 }}"><a href="#{{ item.id }}" class="text-sm text-ink-secondary hover:text-accent">{{ item.text }}</a></li>{% endfor %}</ol>
      </aside>
    {% endif %}
    <div class="prose prose-lg">{{ articleHtml }}</div>
  </section>

  {# Related Stories #}
  {% if relatedStories.length %}
  <section aria-labelledby="related-heading" class="mb-16" data-pagefind-ignore>
    {% set sectionKicker = "Related" %}{% set sectionTitle = "More Investigations" %}{% set sectionId = "related-heading" %}
    {% include "components/section-header.njk" %}
    <div class="bento-grid">
      {% for story in relatedStories %}
        {% set storyAuthor = story.data.author | getAuthor(collections.authorProfiles) %}
        <article class="card bento-4">
          <span class="card__tag">{{ story.data.kicker }}</span>
          <h3 class="font-serif text-lg mt-1"><a href="{{ story.url }}" class="text-ink hover:text-accent">{{ story.data.title }}</a></h3>
          <p class="text-sm text-ink-secondary mt-2">{{ story.data.description }}</p>
          {% set metaDate = story.date %}{% set metaAuthor = storyAuthor.data.name if storyAuthor else null %}{% set metaAuthorUrl = storyAuthor.url if storyAuthor else null %}{% set metaDesk = null %}{% set metaReadTime = null %}
          <div class="mt-3">{% include "components/meta-row.njk" %}</div>
        </article>
      {% endfor %}
    </div>
  </section>
  {% endif %}

</main>
