---
layout: layouts/base.njk
ogType: article
---
{% set authorProfile = author | getAuthor(collections.authorProfiles) %}
{% set articleHtml = content | withHeadingIds %}
{% set tocItems = articleHtml | extractHeadings %}
{% set relatedStories = collections.article | relatedArticles(page, tags, 3) %}
{% if proofCard %}
  <section class="proof-first-shell" data-pagefind-body data-pagefind-meta="type: Proof-backed article">
    <div class="proof-first-shell__slab">
      {% include "components/proof-card.njk" %}
    </div>
  </section>
{% endif %}

<article class="grid gap-10 xl:grid-cols-[minmax(0,1fr)_18rem]">
  <div class="space-y-12">
    <div>
      {% if proofCard %}
        <div class="article-record-transition" data-pagefind-ignore>
          <p class="article-record-transition__label">The Record</p>
          <p class="article-record-transition__text">The reported narrative behind the proof.</p>
        </div>
      {% endif %}

      <header class="article-record-header">
        <div class="sr-only" aria-hidden="true">
          <span data-pagefind-meta="type">Article</span>
          {% if authorProfile %}
            <span data-pagefind-meta="author">{{ authorProfile.data.name }}</span>
            <span data-pagefind-filter="author">{{ authorProfile.data.name }}</span>
          {% endif %}
          <span data-pagefind-filter="year">{{ date | displayYear }}</span>
          {% for tag in tags %}
            {% if tag != "article" %}
              <span data-pagefind-filter="desk">{{ tag | tagLabel }}</span>
            {% endif %}
          {% endfor %}
        </div>
        <p class="section-kicker">{{ kicker or "Investigative Report" }}</p>
        <h1 class="article-record-header__title">
          {{ title }}
        </h1>
        {% if description %}
          <p class="article-record-header__description" data-pagefind-weight="2">
            {{ description }}
          </p>
        {% endif %}
        <div class="meta-row article-record-header__meta">
          <span>By {% if authorProfile %}<a class="hover:text-[rgb(var(--ink))]" href="{{ authorProfile.url }}">{{ authorProfile.data.name }}</a>{% else %}{{ author or site.author }}{% endif %}</span>
          <span class="meta-divider">{{ date | displayDate }}</span>
          <span class="meta-divider">{{ articleHtml | readingMinutes }} min read</span>
        </div>
      </header>

      {% if featured_image %}
        <figure class="my-8 border border-[rgba(var(--rule),0.92)] bg-[rgba(var(--paper-muted),0.7)] p-2">
          {% image featured_image, title, "(min-width: 1024px) 1200px, 100vw", "w-full" %}
        </figure>
      {% endif %}

      <div class="article-prose mx-auto mt-10 max-w-none" data-pagefind-body data-reading-root>
        {{ articleHtml | safe }}
      </div>
    </div>

    {% if authorProfile %}
      <section class="author-card grid gap-5 p-5 md:grid-cols-[auto_1fr] md:p-7" data-pagefind-ignore>
        {% if authorProfile.data.headshot %}
          {% image authorProfile.data.headshot, authorProfile.data.name, "96px", "h-20 w-20 rounded-full object-cover" %}
        {% else %}
          <div class="author-avatar h-20 w-20 text-lg">{{ authorProfile.data.name | initials }}</div>
        {% endif %}
        <div>
          <p class="section-kicker">About the reporter</p>
          <h2 class="mt-2 font-display text-3xl font-black tracking-tight text-[rgb(var(--ink))]">
            <a class="headline-link" href="{{ authorProfile.url }}">{{ authorProfile.data.name }}</a>
          </h2>
          <p class="mt-2 font-ui text-[0.74rem] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--ink-muted))]">
            {{ authorProfile.data.role }}
          </p>
          <p class="mt-4 max-w-3xl font-serif text-base leading-relaxed text-[rgb(var(--ink-soft))]">
            {{ authorProfile.data.bio or authorProfile.data.short_bio }}
          </p>
        </div>
      </section>
    {% endif %}

    {% if relatedStories | length %}
      <section class="space-y-5" data-pagefind-ignore>
        <div class="flex items-end justify-between border-b border-[rgb(var(--rule-strong))] pb-3">
          <h2 class="font-display text-3xl font-black tracking-tight text-[rgb(var(--ink))]">Continue reading</h2>
          <p class="section-kicker">Related desks</p>
        </div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {% for story in relatedStories %}
            {% set storyAuthor = story.data.author | getAuthor(collections.authorProfiles) %}
            <article class="listing-card card-lift p-5">
              <p class="meta-row">
                <span>{{ story.date | displayDate }}</span>
                {% if storyAuthor %}
                  <span class="meta-divider">{{ storyAuthor.data.name }}</span>
                {% endif %}
              </p>
              <h3 class="mt-3 font-serif text-2xl font-black leading-tight text-[rgb(var(--ink))]">
                <a class="headline-link" href="{{ story.url }}">{{ story.data.title }}</a>
              </h3>
              <p class="mt-3 font-serif text-base leading-relaxed text-[rgb(var(--ink-soft))]">
                {{ story.data.description }}
              </p>
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </div>

  <aside class="space-y-5 xl:pt-32" data-pagefind-ignore>
    <div class="rail-card xl:sticky xl:top-6">
      <div class="space-y-5 p-5">
        <section>
          <p class="section-kicker">Reading tools</p>
          <div class="mt-3 flex flex-wrap gap-3">
            <button class="toolbar-button" type="button" data-copy-link data-copy-label-default="Copy link" data-copy-label-success="Link copied">
              Copy link
            </button>
            <button class="toolbar-button" type="button" data-share-page data-share-title="{{ title }}" hidden>
              Share
            </button>
            <button class="toolbar-button" type="button" data-print-page>
              Print
            </button>
          </div>
        </section>

        {% if tocItems | length %}
          <section class="border-t border-[rgba(var(--rule),0.92)] pt-5">
            <p class="section-kicker">On this page</p>
            <nav class="mt-4" aria-label="Article sections">
              <ul class="toc-list">
                {% for item in tocItems %}
                  <li class="{% if item.level > 2 %}ml-4{% endif %}">
                    <a class="toc-link" href="#{{ item.id }}">{{ item.text }}</a>
                  </li>
                {% endfor %}
              </ul>
            </nav>
          </section>
        {% endif %}

        {% if authorProfile %}
          <section class="border-t border-[rgba(var(--rule),0.92)] pt-5">
            <p class="section-kicker">Byline</p>
            <p class="mt-3 font-serif text-xl font-black leading-tight text-[rgb(var(--ink))]">
              <a class="headline-link" href="{{ authorProfile.url }}">{{ authorProfile.data.name }}</a>
            </p>
            <p class="mt-2 font-serif text-sm leading-relaxed text-[rgb(var(--ink-soft))]">
              {{ authorProfile.data.short_bio }}
            </p>
          </section>
        {% endif %}

        <section class="border-t border-[rgba(var(--rule),0.92)] pt-5">
          <p class="section-kicker">Elsewhere</p>
          <div class="mt-3 flex flex-wrap gap-3">
            <a class="button-link-muted" href="/search/">Search archive</a>
            <a class="button-link-muted" href="/rss/">RSS</a>
            <a class="button-link-muted" href="/archives/">Archive</a>
          </div>
        </section>
      </div>
    </div>
  </aside>
</article>
