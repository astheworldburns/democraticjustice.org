---
layout: layouts/base.njk
ogType: article
---
{% set authorProfile = author | getAuthor(collections.authorProfiles) %}
{% set articleHtml = content | withHeadingIds %}
{% set tocItems = articleHtml | extractHeadings %}
{% set relatedStories = collections.article | relatedArticles(page, tags, 3) %}

<article class="story-layout story-layout--bento">
  <div class="story-main space-y-8">
    <header class="story-header">
      <div class="sr-only" aria-hidden="true">
        <span data-pagefind-meta="type">Article</span>
        {% if authorProfile %}
          <span data-pagefind-meta="author">{{ authorProfile.data.name }}</span>
          <span data-pagefind-filter="author">{{ authorProfile.data.name }}</span>
        {% endif %}
        <span data-pagefind-filter="year">{{ date | displayYear }}</span>
        {% for tag in tags %}
          {% if tag != "article" %}
            <span data-pagefind-filter="desk">{{ tag | tagLabel }}</span>
          {% endif %}
        {% endfor %}
      </div>
      <p class="section-kicker">{{ kicker or "Investigative Report" }}</p>
      <h1 class="story-title">{{ title }}</h1>
      {% if description %}
        <p class="story-description" data-pagefind-weight="2">{{ description }}</p>
      {% endif %}
      <div class="meta-row mt-4">
        <span>By {% if authorProfile %}<a class="headline-link" href="{{ authorProfile.url }}">{{ authorProfile.data.name }}</a>{% else %}{{ author or site.author }}{% endif %}</span>
        <span class="meta-divider">{{ date | displayDate }}</span>
        <span class="meta-divider">{{ articleHtml | readingMinutes }} min read</span>
      </div>
    </header>

    {% if proofCard %}
      <section class="proof-shell" data-pagefind-body data-pagefind-meta="type: Proof-backed article">
        {% include "components/proof-card.njk" %}
      </section>
    {% endif %}

    {% if proofCard %}
      <p class="story-transition" data-pagefind-ignore>Reported narrative</p>
    {% endif %}

    {% if featured_image %}
      <figure class="my-4 border border-[rgba(var(--rule),0.8)] bg-[rgba(var(--surface-muted),0.5)] p-2 rounded-[var(--radius-xs)]">
        {% image featured_image, title, "(min-width: 1024px) 1200px, 100vw", "w-full" %}
      </figure>
    {% endif %}

    <div class="story-prose" data-pagefind-body data-reading-root>
      {{ articleHtml | safe }}
    </div>

    {% if authorProfile %}
      <section class="author-card grid gap-4 p-5 md:grid-cols-[auto_1fr]" data-pagefind-ignore>
        {% if authorProfile.data.headshot %}
          {% image authorProfile.data.headshot, authorProfile.data.name, "96px", "h-20 w-20 rounded-full object-cover" %}
        {% else %}
          <div class="author-avatar h-20 w-20 text-lg">{{ authorProfile.data.name | initials }}</div>
        {% endif %}
        <div>
          <p class="section-kicker">About the reporter</p>
          <h2 class="mt-2 font-display text-3xl font-semibold tracking-tight text-[rgb(var(--ink))]">
            <a class="headline-link" href="{{ authorProfile.url }}">{{ authorProfile.data.name }}</a>
          </h2>
          <p class="mt-1 font-mono text-[0.65rem] uppercase tracking-[0.1em] text-[rgb(var(--ink-muted))]">
            {{ authorProfile.data.role }}
          </p>
          <p class="mt-3 font-serif text-[0.98rem] leading-relaxed text-[rgb(var(--ink-soft))]">
            {{ authorProfile.data.bio or authorProfile.data.short_bio }}
          </p>
        </div>
      </section>
    {% endif %}

    {% if relatedStories | length %}
      <section class="space-y-4" data-pagefind-ignore>
        <div class="flex items-end justify-between border-b border-[rgba(var(--rule-strong),0.82)] pb-3">
          <h2 class="font-display text-3xl font-semibold tracking-tight text-[rgb(var(--ink))]">Continue reading</h2>
          <p class="section-kicker">Related desks</p>
        </div>
        <div class="story-bento-grid">
          {% for story in relatedStories %}
            {% set storyAuthor = story.data.author | getAuthor(collections.authorProfiles) %}
            <article class="listing-card card-lift story-bento-card p-4">
              <p class="meta-row">
                <span>{{ story.date | displayDate }}</span>
                {% if storyAuthor %}
                  <span class="meta-divider">{{ storyAuthor.data.name }}</span>
                {% endif %}
              </p>
              <h3 class="mt-2 font-serif text-2xl font-semibold leading-tight text-[rgb(var(--ink))]">
                <a class="headline-link" href="{{ story.url }}">{{ story.data.title }}</a>
              </h3>
              <p class="mt-2 font-serif text-[0.94rem] leading-relaxed text-[rgb(var(--ink-soft))]">
                {{ story.data.description }}
              </p>
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </div>

  <aside class="story-sidebar story-sidebar--bento" data-pagefind-ignore>
    <div class="story-rail">
      <p class="section-kicker">Reading tools</p>
      <div class="mt-3 flex flex-wrap gap-2">
        <button class="toolbar-button" type="button" data-copy-link data-copy-label-default="Copy link" data-copy-label-success="Link copied">
          Copy link
        </button>
        <button class="toolbar-button" type="button" data-share-page data-share-title="{{ title }}" hidden>
          Share
        </button>
        <button class="toolbar-button" type="button" data-print-page>
          Print
        </button>
      </div>
    </div>

    {% if tocItems | length %}
      <div class="story-rail">
        <p class="section-kicker">On this page</p>
        <nav aria-label="Article sections">
          <ul class="toc-list">
            {% for item in tocItems %}
              <li class="{% if item.level > 2 %}ml-4{% endif %}">
                <a class="toc-link" href="#{{ item.id }}">{{ item.text }}</a>
              </li>
            {% endfor %}
          </ul>
        </nav>
      </div>
    {% endif %}

    {% if authorProfile %}
      <div class="story-rail">
        <p class="section-kicker">Byline</p>
        <p class="mt-3 font-serif text-xl font-semibold leading-tight text-[rgb(var(--ink))]">
          <a class="headline-link" href="{{ authorProfile.url }}">{{ authorProfile.data.name }}</a>
        </p>
        <p class="mt-2 font-serif text-[0.9rem] leading-relaxed text-[rgb(var(--ink-soft))]">
          {{ authorProfile.data.short_bio }}
        </p>
      </div>
    {% endif %}

    <div class="story-rail">
      <p class="section-kicker">Elsewhere</p>
      <div class="mt-3 flex flex-wrap gap-2">
        <a class="button-link-muted" href="/search/">Search</a>
        <a class="button-link-muted" href="/rss/">RSS</a>
        <a class="button-link-muted" href="/archives/">Archive</a>
      </div>
    </div>
  </aside>
</article>
