---
layout: layouts/base.njk
ogType: website
---
<section class="page-shell page-shell--bento" data-pagefind-body>
  <header class="page-header">
    <p class="section-kicker">{{ kicker or "Background" }}</p>
    <h1 class="page-title">{{ title }}</h1>
    {% if description %}
      <p class="page-description">{{ description }}</p>
    {% endif %}
  </header>

  <div class="page-prose page-prose--bento">
    {{ content | safe }}
  </div>
</section>
