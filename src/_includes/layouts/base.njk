<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    {% set siteTitle = siteSettings.site_title or site.name %}
    {% set siteMetaDescription = siteSettings.meta_description or site.description %}
    {% set canonicalUrl = page.url | absoluteUrl(site.url) %}
    {% set browserTitle = title + " | " + siteTitle if title and title != siteTitle else siteTitle %}
    {% set socialTitle = title if ogType == "article" and title else browserTitle %}
    {% set socialDescription = socialDescription or (siteMetaDescription if page.url == "/" else description or siteMetaDescription) %}
    {% set socialImagePath = socialImage or (featured_image if featured_image else site.defaultSocialImage) %}
    {% set socialImageUrl = socialImagePath | absoluteUrl(site.url) %}
    {% set assetVersion = buildVersion %}
    {% set faviconHref = site.favicon ~ "?v=" ~ assetVersion %}
    {% set appleTouchHref = site.appleTouchIcon ~ "?v=" ~ assetVersion %}
    {% set authorProfile = author | getAuthor(collections.authorProfiles) if ogType == "article" and author else null %}
    {% set articleAuthorName = authorProfile.data.name if authorProfile else author or siteTitle %}
    {% set articleAuthorUrl = authorProfile.url | absoluteUrl(site.url) if authorProfile else "" %}
    {% set modifiedDate = (updated if updated else date) | machineDate %}
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; worker-src 'self' blob:; object-src 'none'; base-uri 'none'; form-action 'self' https://buttondown.com; frame-src 'self'; upgrade-insecure-requests" />
    <script>
      (function(){
        var t=localStorage.getItem('theme');
        if(!t)t=window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';
        document.documentElement.setAttribute('data-theme',t);
      })();
    </script>
    <title>{{ browserTitle }}</title>
    <meta name="description" content="{{ socialDescription }}" />
    <meta name="generator" content="Eleventy v3" />
    <meta name="theme-color" content="#f1eee8" data-theme-color />
    <meta property="og:title" content="{{ socialTitle }}" />
    <meta property="og:description" content="{{ socialDescription }}" />
    <meta property="og:type" content="{{ ogType | default('website') }}" />
    <meta property="og:url" content="{{ canonicalUrl }}" />
    <meta property="og:site_name" content="{{ siteTitle }}" />
    <meta property="og:image" content="{{ socialImageUrl }}" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ socialTitle }}" />
    <meta name="twitter:description" content="{{ socialDescription }}" />
    <meta name="twitter:image" content="{{ socialImageUrl }}" />
    {% if ogType == "article" %}
      <meta property="article:author" content="{{ articleAuthorName }}" />
      <meta property="article:published_time" content="{{ date | machineDate }}" />
      <meta property="article:modified_time" content="{{ modifiedDate }}" />
      {% if kicker %}<meta property="article:section" content="{{ kicker }}" />{% endif %}
      {% for tag in tags %}{% if tag != "article" %}<meta property="article:tag" content="{{ tag }}" />{% endif %}{% endfor %}
    {% endif %}
    <link rel="canonical" href="{{ canonicalUrl }}" />
    <link rel="icon" type="image/svg+xml" sizes="any" href="{{ faviconHref }}" />
    <link rel="shortcut icon" href="{{ faviconHref }}" />
    <link rel="apple-touch-icon" href="{{ appleTouchHref }}" />
    <link rel="alternate" type="application/rss+xml" title="{{ siteTitle }} RSS Feed" href="/feed.xml" />
    <link rel="preload" href="/assets/fonts/space-grotesk-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/assets/fonts/source-serif-4-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/assets/css/style.css?v={{ assetVersion }}" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            "@id": "{{ site.url }}/#organization",
            "name": "{{ siteTitle | replace('"', '\\"') }}",
            "url": "{{ site.url }}",
            "logo": "{{ site.proofMarkDay | absoluteUrl(site.url) }}"
          },
          {
            "@type": "WebSite",
            "@id": "{{ site.url }}/#website",
            "url": "{{ site.url }}",
            "name": "{{ siteTitle | replace('"', '\\"') }}",
            "publisher": { "@id": "{{ site.url }}/#organization" },
            "potentialAction": {
              "@type": "SearchAction",
              "target": "{{ '/search/?q={search_term_string}' | absoluteUrl(site.url) }}",
              "query-input": "required name=search_term_string"
            }
          }
        ]
      }
    </script>

    {% if ogType == "article" %}
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "NewsArticle",
          "@id": "{{ canonicalUrl }}#article",
          "mainEntityOfPage": "{{ canonicalUrl }}",
          "headline": "{{ title | replace('"', '\\"') }}",
          "description": "{{ socialDescription | replace('"', '\\"') }}",
          "datePublished": "{{ date | machineDate }}",
          "dateModified": "{{ modifiedDate }}",
          "author": {
            "@type": "Person",
            "name": "{{ articleAuthorName | replace('"', '\\"') }}"{% if articleAuthorUrl %},
            "url": "{{ articleAuthorUrl }}"{% endif %}
          },
          "publisher": { "@id": "{{ site.url }}/#organization" },
          "image": {"@type":"ImageObject","url":"{{ site.url }}{{ socialImage | default(site.defaultSocialImage) }}","width":1200,"height":630}{% if proofCard and proofCard.sourceDocuments | length %},
          "isBasedOn": [
            {% for source in proofCard.sourceDocuments %}"{{ source.documentUrl | absoluteUrl(site.url) }}"{% if not loop.last %},{% endif %}{% endfor %}
          ]{% endif %}{% if tags %},
          "articleSection": [
            {% set firstSection = true %}
            {% for tag in tags %}
              {% if tag != "article" %}
                {% if not firstSection %},{% endif %}"{{ tag | tagLabel | replace('"', '\\"') }}"
                {% set firstSection = false %}
              {% endif %}
            {% endfor %}
          ]{% endif %}
        }
      </script>
    {% endif %}

    {% if extraHead %}{{ extraHead | safe }}{% endif %}
  </head>
  <body class="antialiased">
    <div class="reading-progress" aria-hidden="true">
      <span class="reading-progress__bar" data-reading-progress></span>
    </div>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="site-frame">
      <div class="site-panel">
        {% include "components/header.njk" %}
        <main id="main-content"{% if page.url != "/" %} class="main-shell"{% endif %}>
          {{ content | safe }}
        </main>
        {% include "components/footer.njk" %}
      </div>
    </div>
    <script src="/assets/js/site.js?v={{ assetVersion }}" defer></script>
    {% if pageScripts %}{{ pageScripts | safe }}{% endif %}
  </body>
</html>
