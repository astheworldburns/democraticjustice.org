---
layout: layouts/base.njk
---
{% set reporterStories = collections.article | articlesByAuthor(page.fileSlug) %}
{% set reporterTags = reporterStories | uniqueEditorialTags(4) %}
<section class="space-y-10" data-pagefind-body>
  <header class="border-b-2 border-[rgb(var(--rule-strong))] pb-8">
    <p class="section-kicker">Newsroom</p>
    <div class="mt-5 grid gap-8 xl:grid-cols-[minmax(0,1.2fr)_18rem]">
      <div class="grid gap-5 md:grid-cols-[auto_1fr] md:items-end">
        {% if headshot %}
          {% image headshot, name, "128px", "h-24 w-24 rounded-full object-cover" %}
        {% else %}
          <div class="author-avatar h-24 w-24 text-xl">{{ name | initials }}</div>
        {% endif %}
        <div>
          <div class="sr-only" aria-hidden="true">
            <span data-pagefind-filter="author">{{ name }}</span>
            <span data-pagefind-meta="type">Staff profile</span>
          </div>
          <h1 class="font-display text-[clamp(2.8rem,5vw,4.5rem)] font-black leading-[0.95] tracking-tight text-[rgb(var(--ink))]">
            {{ name }}
          </h1>
          <p class="mt-3 font-ui text-[0.78rem] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--ink-muted))]">
            {{ role }}
          </p>
          <p class="mt-4 max-w-4xl font-serif text-lg leading-relaxed text-[rgb(var(--ink-soft))]">
            {{ bio or short_bio }}
          </p>
        </div>
      </div>
      <aside class="space-y-4">
        <div class="tool-card p-5">
          <p class="section-kicker">Reporting brief</p>
          <p class="stat-card__value">{{ reporterStories | length }}</p>
          <p class="stat-card__caption">Published reports under this byline.</p>
        </div>
        {% if reporterTags | length %}
          <div class="tool-card p-5">
            <p class="section-kicker">Primary desks</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {% for tag in reporterTags %}
                <a class="story-chip" href="/category/{{ tag | slugifyTag }}/">{{ tag | tagLabel }}</a>
              {% endfor %}
            </div>
          </div>
        {% endif %}
        {% if email or bluesky or twitter %}
          <div class="tool-card p-5">
            <p class="section-kicker">Contact</p>
            <div class="social-list mt-4">
              {% if email %}
                <a class="social-link" href="mailto:{{ email }}">Email</a>
              {% endif %}
              {% if bluesky %}
                <a class="social-link" href="{{ bluesky }}">Bluesky</a>
              {% endif %}
              {% if twitter %}
                <a class="social-link" href="{{ twitter }}">X</a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </aside>
    </div>
  </header>

  <section class="space-y-5">
    <div class="flex items-end justify-between border-b border-[rgb(var(--rule-strong))] pb-3">
      <h2 class="font-display text-3xl font-black tracking-tight text-[rgb(var(--ink))]">Recent reporting</h2>
      <p class="section-kicker">By {{ name }}</p>
    </div>
    <div class="grid gap-4">
      {% for story in reporterStories %}
        <article class="listing-card card-lift p-5 md:p-6">
          <p class="meta-row">
            <span>{{ story.date | displayDate }}</span>
            <span class="meta-divider">{{ story.templateContent | readingMinutes }} min read</span>
          </p>
          <h3 class="mt-3 font-serif text-3xl font-black leading-tight text-[rgb(var(--ink))]">
            <a class="headline-link" href="{{ story.url }}">{{ story.data.title }}</a>
          </h3>
          <p class="mt-3 max-w-3xl font-serif text-base leading-relaxed text-[rgb(var(--ink-soft))]">
            {{ story.data.description }}
          </p>
        </article>
      {% endfor %}
    </div>
  </section>
</section>
