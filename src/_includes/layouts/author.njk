---
layout: layouts/base.njk
---
{% set reporterStories = collections.article | articlesByAuthor(page.fileSlug) %}
<section class="page-shell page-shell--bento author-shell" data-pagefind-body>
  <header class="page-header">
    <p class="section-kicker">Newsroom</p>
    <div class="mt-4 grid gap-5 md:grid-cols-[auto_1fr] md:items-end">
      {% if headshot %}
        {% image headshot, name, "128px", "h-24 w-24 rounded-full object-cover" %}
      {% else %}
        <div class="author-avatar h-24 w-24 text-xl">{{ name | initials }}</div>
      {% endif %}
      <div>
        <div class="sr-only" aria-hidden="true">
          <span data-pagefind-filter="author">{{ name }}</span>
          <span data-pagefind-meta="type">Staff profile</span>
        </div>
        <h1 class="page-title mt-0">{{ name }}</h1>
        <p class="mt-2 font-mono text-2xs uppercase tracking-wide text-ink-muted">{{ role }}</p>
        <p class="mt-3 max-w-4xl font-serif text-base leading-relaxed text-ink-secondary">{{ bio or short_bio }}</p>
      </div>
    </div>
    <div class="mt-4 flex flex-wrap items-center gap-2">
      <span class="story-chip">{{ reporterStories | length }} published</span>
      {% if email %}<a class="button-link-muted" href="mailto:{{ email }}">Email</a>{% endif %}
      {% if bluesky %}<a class="button-link-muted" href="{{ bluesky }}">Bluesky</a>{% endif %}
      {% if twitter %}<a class="button-link-muted" href="{{ twitter }}">X</a>{% endif %}
    </div>
  </header>

  <section class="space-y-4">
    <div class="flex items-end justify-between border-b border-border pb-3">
      <h2 class="font-display text-3xl font-semibold tracking-tight text-ink">Recent reporting</h2>
      <p class="section-kicker">By {{ name }}</p>
    </div>
    <div class="author-story-grid">
      {% for story in reporterStories %}
        <article class="listing-card card-lift author-story-card p-4">
          <p class="meta-row">
            <span>{{ story.date | displayDate }}</span>
            <span class="meta-divider">{{ story.templateContent | readingMinutes }} min read</span>
          </p>
          <h3 class="mt-2 font-serif text-2xl font-semibold leading-tight text-ink">
            <a class="headline-link" href="{{ story.url }}">{{ story.data.title }}</a>
          </h3>
          <p class="mt-2 max-w-3xl font-serif text-base leading-relaxed text-ink-secondary">{{ story.data.description }}</p>
        </article>
      {% endfor %}
    </div>
  </section>
</section>
