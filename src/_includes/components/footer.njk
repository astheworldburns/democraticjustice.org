{% set siteTitle = siteSettings.site_title or site.name %}
{% set footerDescription = siteSettings.footer_description or site.description %}

<footer class="site-footer">
  <div class="site-footer__grid">
    <div>
      <p class="site-footer__title">{{ siteTitle }}</p>
      <p class="site-footer__description">{{ footerDescription }}</p>
    </div>

    <div class="site-footer__links">
      <a class="footer-link" href="mailto:{{ site.contactEmail }}">{{ site.contactEmail }}</a>
      <a class="footer-link" href="/archives/">Reporting archive</a>
      <a class="footer-link" href="/documents/">Source documents</a>
      <a class="footer-link" href="/search/">Search</a>
      <a class="footer-link" href="/subscribe/">Subscribe</a>
      <a class="footer-link" href="/rss/">RSS</a>
      <a class="footer-link" href="/standards/">Editorial Standards</a>
      <a class="footer-link" href="/corrections/">Corrections</a>
      <a class="footer-link" href="/contact/">Contact</a>
      <a class="footer-link" href="/privacy/">Privacy</a>
      <a class="footer-link" href="/cookies/">Cookies</a>
    </div>
  </div>

  <p class="footer-note">&copy; {{ buildDate | displayYear }} {{ siteTitle }}. All rights reserved.</p>
</footer>
