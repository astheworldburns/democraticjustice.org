{% set proofMarkDaySrc = site.proofMarkDay ~ "?v=" ~ buildVersion %}
{% set proofMarkNightSrc = site.proofMarkNight ~ "?v=" ~ buildVersion %}
{% set proofMarkPrintSrc = site.proofMarkPrint ~ "?v=" ~ buildVersion %}
{% set siteTitle = siteSettings.site_title or site.name %}
{% set footerDescription = siteSettings.footer_description or site.description %}
{% set standardsTagline = siteSettings.standards_tagline or "Reported. Attributed. Archived." %}

<footer class="border-t border-[rgb(var(--rule-strong))] bg-[rgba(var(--paper-muted),0.72)] px-5 py-10 md:px-10">
  <div class="grid gap-8 lg:grid-cols-[minmax(0,1.25fr)_minmax(15rem,0.75fr)_minmax(14rem,0.7fr)]">
    <div>
      <a class="masthead-brand masthead-brand--footer" href="/" aria-label="{{ siteTitle }}">
        <img class="proof-mark masthead-brand__mark masthead-brand__mark--footer" data-proof-mark data-proof-mark-day="{{ proofMarkDaySrc }}" data-proof-mark-night="{{ proofMarkNightSrc }}" data-proof-mark-print="{{ proofMarkPrintSrc }}" src="{{ proofMarkDaySrc }}" alt="" />
        <span class="masthead-brand__copy">
          <span class="masthead-brand__name masthead-brand__name--footer">{{ siteTitle }}</span>
        </span>
      </a>
      <p class="mt-3 max-w-2xl font-serif text-base leading-relaxed text-[rgb(var(--ink-soft))]">
        {{ footerDescription }}
      </p>
    </div>
    <div>
      <p class="section-kicker">Contact</p>
      <div class="mt-3 space-y-3 font-ui text-[0.78rem] font-semibold uppercase tracking-[0.16em] text-[rgb(var(--ink-soft))]">
        <a class="block hover:text-[rgb(var(--ink))]" href="mailto:{{ site.contactEmail }}">{{ site.contactEmail }}</a>
        <a class="block hover:text-[rgb(var(--ink))]" href="/feed.xml">Full-content RSS</a>
        <a class="block hover:text-[rgb(var(--ink))]" href="/search/">Search the archive</a>
        <a class="block hover:text-[rgb(var(--ink))]" href="/staff/">Staff directory</a>
      </div>
    </div>
    <div>
      <p class="section-kicker">Standards</p>
      <p class="mt-3 font-serif text-sm leading-relaxed text-[rgb(var(--ink-soft))]">
        Lead with verified facts, name who holds power, attribute claims directly, and publish work in forms built to remain accessible over time.
      </p>
      <p class="mt-4 font-ui text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--ink-muted))]">
        {{ standardsTagline }}
      </p>
    </div>
  </div>
  <p class="mt-8 border-t border-[rgba(var(--rule),0.92)] pt-4 font-ui text-[0.7rem] uppercase tracking-[0.18em] text-[rgb(var(--ink-muted))]">
    &copy; {{ buildDate | displayYear }} {{ siteTitle }}. All rights reserved.
  </p>
</footer>
