{% set isHomePage = page.url == "/" %}
{% set isArticlePage = ogType == "article" %}
{% set proofMarkDaySrc = site.proofMarkDay ~ "?v=" ~ buildVersion %}
{% set proofMarkNightSrc = site.proofMarkNight ~ "?v=" ~ buildVersion %}
{% set proofMarkPrintSrc = site.proofMarkPrint ~ "?v=" ~ buildVersion %}
{% set siteTitle = siteSettings.site_title or site.name %}
{% set siteTagline = siteSettings.tagline or site.tagline %}

<header class="site-header">
  <div class="site-header__top">
    <div class="brand">
      <a class="brand__link" href="/" aria-label="{{ siteTitle }}">
        <img class="proof-mark brand__mark" data-proof-mark data-proof-mark-day="{{ proofMarkDaySrc }}" data-proof-mark-night="{{ proofMarkNightSrc }}" data-proof-mark-print="{{ proofMarkPrintSrc }}" src="{{ proofMarkDaySrc }}" alt="" />
        <span class="brand__title">{{ siteTitle }}</span>
      </a>
      {% if siteTagline %}
        <p class="brand__tagline">{{ siteTagline }}</p>
      {% endif %}
    </div>

    <div class="site-header__meta">
      {% if not isArticlePage %}
        <p class="edition-line">Edition <time data-edition-date>{{ buildDate | displayDate }}</time></p>
      {% else %}
        <p class="edition-line">Proof-backed report</p>
      {% endif %}
      <button class="theme-toggle" type="button" data-theme-toggle>
        <span data-theme-label>Night edition</span>
      </button>
    </div>
  </div>

  <nav aria-label="Primary" class="primary-nav">
    <ul class="primary-nav__list">
      <li><a class="primary-nav__link" href="/" {% if page.url == '/' %}aria-current="page"{% endif %}>Home</a></li>
      <li><a class="primary-nav__link" href="/archives/" {% if page.url == '/archives/' %}aria-current="page"{% endif %}>Archives</a></li>
      <li><a class="primary-nav__link" href="/documents/" {% if page.url == '/documents/' %}aria-current="page"{% endif %}>Documents</a></li>
      <li><a class="primary-nav__link" href="/search/" {% if page.url == '/search/' %}aria-current="page"{% endif %}>Search</a></li>
      {% if not isArticlePage %}
        <li><a class="primary-nav__link" href="/staff/" {% if page.url == '/staff/' %}aria-current="page"{% endif %}>Staff</a></li>
        <li><a class="primary-nav__link" href="/about/" {% if page.url == '/about/' %}aria-current="page"{% endif %}>About</a></li>
        <li><a class="primary-nav__link" href="/subscribe/" {% if page.url == '/subscribe/' %}aria-current="page"{% endif %}>Subscribe</a></li>
        <li><a class="primary-nav__link" href="/rss/" {% if page.url == '/rss/' %}aria-current="page"{% endif %}>RSS</a></li>
      {% endif %}
    </ul>
  </nav>
</header>
