{% set shareUrl = site.url ~ page.url %}
{% set shareTitle = shareTitle or "Share this story" %}
{% set shareDeck = shareDeck or "If this reporting matters, send it to someone who should see it." %}

<div class="max-w-3xl mx-auto lead-card news-grid-accent p-5 md:p-6" data-pagefind-ignore aria-label="{{ shareTitle }}">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-2xl">
      <p class="card__tag">Spread the story</p>
      <p class="font-serif text-2xl leading-tight text-ink">{{ shareTitle }}</p>
      <p class="mt-2 font-ui text-sm leading-relaxed text-ink-secondary">{{ shareDeck }}</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <button
        type="button"
        class="button-link"
        data-share-page
        data-share-title="{{ title }}"
        data-share-url="{{ shareUrl }}"
        hidden
      >
        Share story
      </button>
      <button
        type="button"
        class="button-link-muted"
        data-copy-link
        data-copy-value="{{ shareUrl }}"
        data-copy-label-default="Copy link"
        data-copy-label-success="Link copied"
      >
        Copy link
      </button>
    </div>
  </div>

  {% if showShareUrl %}
    <p class="mt-4 border-t border-border-subtle pt-4 text-sm text-ink-secondary">
      Link to this story:
      <a href="{{ shareUrl }}" class="underline underline-offset-2 decoration-1 break-words text-ink hover:text-accent">{{ shareUrl }}</a>
    </p>
  {% endif %}
</div>
