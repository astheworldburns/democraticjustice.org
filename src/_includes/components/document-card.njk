<article class="card">
  {% set docFileHref = docFile %}
  {% if docFile and not docFile.startsWith("/") %}
    {% set docFileHref = "/" + docFile %}
  {% endif %}
  {% if docSourceMethod %}
    <span class="card__tag">{{ docSourceMethod }}</span>
  {% endif %}
  <h3 class="font-serif text-lg mt-1">{{ docTitle }}</h3>
  {% if docDescription %}
    <p class="text-sm text-ink-secondary mt-2">{{ docDescription }}</p>
  {% endif %}
  <dl class="mt-3 font-mono text-xs text-ink-muted space-y-1">
    {% if docObtained %}
      <div class="flex gap-2">
        <dt>Obtained</dt>
        <dd><time datetime="{{ docObtained | machineDate }}">{{ docObtained | displayDate }}</time></dd>
      </div>
    {% endif %}
    {% if docFileType %}
      <div class="flex gap-2">
        <dt>Format</dt>
        <dd class="uppercase">{{ docFileType }}</dd>
      </div>
    {% elseif docVideoUrl %}
      <div class="flex gap-2">
        <dt>Format</dt>
        <dd class="uppercase">VIDEO</dd>
      </div>
    {% endif %}
  </dl>
  <div class="mt-4 flex gap-3">
    <a href="{{ docUrl }}" class="font-mono text-sm text-accent hover:underline">View {{ docTitle }} →</a>
    {% if docFile %}
      <a href="{{ docFileHref }}" class="font-mono text-sm text-ink-muted hover:underline" download>
        Download {{ docFileType | default("file") | upper }}
      </a>
    {% endif %}
    {% if docVideoUrl %}
      <a href="{{ docVideoUrl }}" class="font-mono text-sm text-ink-muted hover:underline" target="_blank" rel="noreferrer">
        Watch video
      </a>
    {% endif %}
  </div>
</article>
