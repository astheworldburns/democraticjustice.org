{% set proofMarkDaySrc = site.proofMarkDay ~ "?v=" ~ buildVersion %}
{% set proofMarkNightSrc = site.proofMarkNight ~ "?v=" ~ buildVersion %}
{% set proofMarkPrintSrc = site.proofMarkPrint ~ "?v=" ~ buildVersion %}

<section id="proof-card" aria-labelledby="proof-heading" class="mb-16">
  <div class="bento-grid">
    <div class="card card--featured bento-8 bento-rows-2">
      <span class="card__tag">{{ kicker }}</span>
      <h1 id="proof-heading" class="font-serif text-display-lg">{{ title }}</h1>
      <p class="font-serif text-lg text-ink-secondary italic mt-4">{{ proofCard.issue }}</p>
      {% set metaDesk = kicker %}{% set metaAuthor = authorProfile.data.name if authorProfile else author %}{% set metaAuthorUrl = authorProfile.url if authorProfile else null %}{% set metaDate = date %}{% set metaReadTime = content | readingMinutes %}
      <div class="mt-6">{% include "components/meta-row.njk" %}</div>
    </div>

    <div class="card bento-4" id="proof-axioms">
      <h2 class="section-header__kicker">Axioms <span class="text-ink-muted">({{ proofCard.axiomCount }})</span></h2>
      <ol class="space-y-3 mt-3">
        {% for axiom in proofCard.axioms %}
          <li class="text-sm leading-relaxed">
            <span class="font-mono text-xs text-ink-muted mr-1">{{ axiom.index }}.</span>
            {{ axiom.premise }}
            {% if axiom.sources.length %}
              <span class="inline-flex gap-1 ml-1">
                {% for source in axiom.sources %}
                  {% set sourceRecord = source.documentUrl | getSourceDocument(collections.sourceDocument) %}
                  <a href="{{ source.documentUrl }}" class="proof-doc-link text-accent text-xs font-mono hover:underline" data-doc-url="{{ source.documentUrl }}" title="{{ sourceRecord.data.title if sourceRecord else source.label }}">[{{ loop.index }}]</a>
                {% endfor %}
              </span>
            {% endif %}
          </li>
        {% endfor %}
      </ol>
    </div>

    <div class="card bento-4" id="proof-logic">
      <h2 class="section-header__kicker">Logic <span class="text-ink-muted">({{ proofCard.logicCount }})</span></h2>
      <ol class="space-y-3 mt-3">
        {% for entry in proofCard.logic %}
          <li class="text-sm leading-relaxed">
            <span class="font-mono text-xs text-ink-muted mr-1">{{ entry.index }}.</span>
            {{ entry.step }}
          </li>
        {% endfor %}
      </ol>
    </div>

    <div class="card bento-8" id="proof-conclusion">
      <h2 class="section-header__kicker">Conclusion</h2>
      <p class="font-serif text-lg leading-relaxed mt-2">{{ proofCard.conclusion }}</p>
    </div>

    <div class="card bento-4" id="proof-documents">
      <h2 class="section-header__kicker">Documents <span class="text-ink-muted">({{ proofCard.sourceDocumentCount }})</span></h2>
      <ul class="space-y-3 mt-3">
        {% for doc in proofCard.sourceDocuments %}
          <li>
            <a href="{{ doc.url }}" class="proof-doc-link group flex items-start gap-2 text-sm" data-doc-url="{{ doc.url }}">
              <span class="text-accent flex-shrink-0">📄</span>
              <span class="group-hover:text-accent transition-colors">{{ doc.data.title if doc.data else "Document " + loop.index }}</span>
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <img class="proof-mark proof-card__mark" src="{{ proofMarkPrintSrc }}" alt="" aria-hidden="true" />
</section>
