{% set variant = proofCardVariant or "inline" %}
{% set standalone = variant == "standalone" %}
<section class="proof-card {% if standalone %}proof-card--standalone{% endif %}" aria-labelledby="proof-card-heading-{{ proofCard.slug }}">
  <header class="proof-card__header">
    <p class="section-kicker">Proof Card</p>
    <h2 id="proof-card-heading-{{ proofCard.slug }}" class="proof-card__heading">
      {% if standalone %}
        Democratic Justice publishes the following conclusion as proved.
      {% else %}
        This investigation carries a published proof.
      {% endif %}
    </h2>
    <ul class="proof-card__meta" aria-label="Proof structure">
      <li>{{ proofCard.axiomCount }} axioms</li>
      <li>{{ proofCard.logicCount }} logic steps</li>
      <li>Binary standard</li>
    </ul>
  </header>

  <div class="proof-card__body">
    <section class="proof-card__lede">
      <div class="proof-card__summary">
        <p class="proof-card__label">Issue</p>
        <p class="proof-card__issue">{{ proofCard.issue }}</p>
      </div>
      <div class="proof-card__summary proof-card__summary--conclusion">
        <p class="proof-card__label">Conclusion</p>
        <p class="proof-card__conclusion">{{ proofCard.conclusionMarked }}</p>
      </div>
    </section>

    <div class="proof-card__columns">
      <section class="proof-card__group">
        <div class="proof-card__group-head">
          <p class="proof-card__label">Axioms</p>
          <p class="proof-card__section-note">Documented, source-linked facts</p>
        </div>
        <ol class="proof-card__list" aria-label="Axioms">
          {% for axiom in proofCard.axioms %}
            <li class="proof-card__list-item">
              <p class="proof-card__list-text">
                <span class="proof-card__marker">A{{ axiom.index }}</span>
                {{ axiom.premise }}
              </p>
              <a class="proof-card__source-link" href="{{ axiom.sourceUrl }}">{{ axiom.sourceLabel }}</a>
            </li>
          {% endfor %}
        </ol>
      </section>

      <section class="proof-card__group">
        <div class="proof-card__group-head">
          <p class="proof-card__label">Logic</p>
          <p class="proof-card__section-note">Each step follows from the prior one</p>
        </div>
        <ol class="proof-card__list" aria-label="Logic chain">
          {% for entry in proofCard.logic %}
            <li class="proof-card__list-item">
              <p class="proof-card__list-text">
                <span class="proof-card__marker">L{{ entry.index }}</span>
                {{ entry.step }}
              </p>
            </li>
          {% endfor %}
        </ol>
      </section>
    </div>

    <section class="proof-card__group">
      <p class="proof-card__label">Inference</p>
      <p class="proof-card__inference">{{ proofCard.inference }}</p>
    </section>
  </div>

  <footer class="proof-card__footer">
    <p class="proof-card__footer-text">
      {% if standalone %}
        This proof accompanies <a class="headline-link" href="{{ proofCard.articleUrl }}">{{ proofCard.articleTitle }}</a>.
      {% else %}
        This Proof Card has its own citation surface and share image for this investigation.
      {% endif %}
    </p>
    <div class="proof-card__links">
      {% if standalone %}
        <a class="button-link-muted" href="{{ proofCard.articleUrl }}">Read the full article</a>
        <a class="button-link-muted" href="{{ proofCard.shareImagePath }}">Open proof image</a>
      {% else %}
        <a class="button-link-muted" href="{{ proofCard.proofUrl }}">Open standalone proof</a>
        <a class="button-link-muted" href="{{ proofCard.shareImagePath }}">Open proof image</a>
      {% endif %}
    </div>
  </footer>
</section>
