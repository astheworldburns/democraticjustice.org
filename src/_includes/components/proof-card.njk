{% set variant = proofCardVariant or "inline" %}
{% set standalone = variant == "standalone" %}
{% set proofMarkDaySrc = site.proofMarkDay ~ "?v=" ~ buildVersion %}
{% set proofMarkNightSrc = site.proofMarkNight ~ "?v=" ~ buildVersion %}
{% set proofMarkPrintSrc = site.proofMarkPrint ~ "?v=" ~ buildVersion %}
<section class="proof-card {% if standalone %}proof-card--standalone{% else %}proof-card--inline{% endif %}" aria-labelledby="proof-card-issue-{{ proofCard.slug }}">
  <header class="proof-card__header">
    <div class="proof-card__identity">
      <img class="proof-mark proof-card__mark" data-proof-mark data-proof-mark-day="{{ proofMarkDaySrc }}" data-proof-mark-night="{{ proofMarkNightSrc }}" data-proof-mark-print="{{ proofMarkPrintSrc }}" src="{{ proofMarkDaySrc }}" alt="" />
      <div class="proof-card__identity-copy">
        <p class="proof-card__eyebrow">Proof</p>
        <p class="proof-card__eyebrow-note">
          {% if standalone %}
            Published as a formal Democratic Justice proof.
          {% else %}
            This investigation includes a published proof.
          {% endif %}
        </p>
      </div>
    </div>
    <p class="proof-card__counts">{{ proofCard.axiomCount }} axioms · {{ proofCard.logicCount }} propositions</p>
  </header>

  <section class="proof-card__issue-block" aria-label="Issue under proof">
    <p class="proof-card__label">Issue</p>
    <h2 id="proof-card-issue-{{ proofCard.slug }}" class="proof-card__issue">{{ proofCard.issue }}</h2>
  </section>

  <div class="proof-card__details">
    <section class="proof-card__section">
      <div class="proof-card__section-head">
        <p class="proof-card__label">Axioms</p>
      </div>
      <div class="proof-card__section-body">
        <ol class="proof-card__list" aria-label="Axioms">
          {% for axiom in proofCard.axioms %}
            <li class="proof-card__list-item">
              <span class="proof-card__marker">A{{ axiom.index }}</span>
              <div class="proof-card__item-copy">
                <p class="proof-card__list-text">{{ axiom.premise }}</p>
                <a class="proof-card__source-link" href="{{ axiom.sourceUrl }}">{{ axiom.sourceLabel }}</a>
              </div>
            </li>
          {% endfor %}
        </ol>
      </div>
    </section>

    <section class="proof-card__section">
      <div class="proof-card__section-head">
        <p class="proof-card__label">Propositions</p>
      </div>
      <div class="proof-card__section-body">
        <ol class="proof-card__list" aria-label="Propositions">
          {% for entry in proofCard.logic %}
            <li class="proof-card__list-item">
              <span class="proof-card__marker">P{{ entry.index }}</span>
              <div class="proof-card__item-copy">
                <p class="proof-card__list-text">{{ entry.step }}</p>
              </div>
            </li>
          {% endfor %}
        </ol>
        <p class="proof-card__bridge"><span class="proof-card__bridge-prefix">Inference:</span> {{ proofCard.inference }}</p>
      </div>
    </section>
  </div>

  <section class="proof-card__conclusion-block" aria-label="Conclusion">
    <p class="proof-card__label">Conclusion</p>
    <div class="proof-card__conclusion-body">
      <img class="proof-card__ghost-mark" src="{{ proofMarkDaySrc }}" alt="" aria-hidden="true" />
      <p class="proof-card__conclusion">
      <span>{{ proofCard.conclusion }}</span>
      </p>
    </div>
  </section>

  <footer class="proof-card__footer">
    <p class="proof-card__footer-text">
      {% if standalone %}
        This proof accompanies <a class="headline-link" href="{{ proofCard.articleUrl }}">{{ proofCard.articleTitle }}</a>.
      {% else %}
        Cite or share this proof separately from the article.
      {% endif %}
    </p>
    <div class="proof-card__links">
      {% if standalone %}
        <a class="proof-card__link" href="{{ proofCard.articleUrl }}">Read the full article</a>
        <a class="proof-card__link" href="{{ proofCard.shareImagePath }}">Open proof image</a>
      {% else %}
        <a class="proof-card__link" href="{{ proofCard.proofUrl }}">Open standalone proof</a>
        <a class="proof-card__link" href="{{ proofCard.shareImagePath }}">Open proof image</a>
      {% endif %}
    </div>
  </footer>
</section>
