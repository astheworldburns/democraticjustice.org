<section id="proof-card" aria-labelledby="proof-heading" class="proof-card-shell mb-12 max-w-3xl">
  <article class="proof-card proof-card--unified">
    <div class="proof-card__topbar">
      <p class="proof-card__eyebrow" id="proof-heading">PROOF</p>
      <p class="proof-card__counts">
        <span><span class="proof-card__count-num">{{ proofCard.axiomCount }}</span> Axioms</span>
        <span><span class="proof-card__count-num">{{ proofCard.postulateCount }}</span> Postulates</span>
        <span><span class="proof-card__count-num">{{ proofCard.theoremCount }}</span> Theorems</span>
      </p>
    </div>

    <header class="proof-card__header">
      <h2 class="proof-card__issue">{{ proofCard.issue }}</h2>
    </header>

    <section class="proof-card__section" aria-labelledby="proof-axioms-label">
      <h3 id="proof-axioms-label" class="proof-card__label">Axioms</h3>
      <ol class="proof-card__items">
        {% for axiom in proofCard.axioms %}
          <li class="proof-card__item">
            <span class="proof-card__item-prefix">{{ axiom.id or ("A" ~ axiom.index) }}</span>
            <span class="proof-card__item-text">{{ axiom.premise }}</span>
            {% if axiom.sources.length %}
              <span class="proof-card__citations">
                {% for source in axiom.sources %}
                  {% set sourceRecord = source.documentUrl | getSourceDocument(collections.sourceDocument) %}
                  <a href="{{ source.documentUrl }}" class="proof-card__citation-link" data-doc-url="{{ source.documentUrl }}" title="{{ sourceRecord.data.title if sourceRecord else source.label }}">{{ loop.index }}</a>
                {% endfor %}
              </span>
            {% endif %}
          </li>
        {% endfor %}
      </ol>
    </section>

    {% if proofCard.postulateCount > 0 %}
      <section class="proof-card__section" aria-labelledby="proof-postulates-label">
        <h3 id="proof-postulates-label" class="proof-card__label">Postulates</h3>
        <ol class="proof-card__items">
          {% for postulate in proofCard.postulates %}
            <li class="proof-card__item">
              <span class="proof-card__item-prefix">{{ postulate.id or ("P" ~ postulate.index) }}</span>
              <span class="proof-card__item-text">{{ postulate.fact }}</span>
              {% if postulate.sources.length %}
                <span class="proof-card__citations">
                  {% for source in postulate.sources %}
                    {% set sourceRecord = source.documentUrl | getSourceDocument(collections.sourceDocument) %}
                    <a href="{{ source.documentUrl }}" class="proof-card__citation-link" data-doc-url="{{ source.documentUrl }}" title="{{ sourceRecord.data.title if sourceRecord else source.label }}">{{ loop.index }}</a>
                  {% endfor %}
                </span>
              {% endif %}
            </li>
          {% endfor %}
        </ol>
      </section>
    {% endif %}

    <section class="proof-card__section proof-card__section--theorems" aria-labelledby="proof-theorems-label">
      <h3 id="proof-theorems-label" class="proof-card__label">Theorems</h3>
      <ol class="proof-card__items">
        {% for theorem in proofCard.theorems %}
          <li class="proof-card__item">
            <span class="proof-card__item-prefix">{{ theorem.id or ("T" ~ theorem.index) }}</span>
            <span class="proof-card__item-text">
              {{ theorem.step }}{% if theorem.references %} <span class="proof-card__references">({{ theorem.references }})</span>{% endif %}
            </span>
          </li>
        {% endfor %}
      </ol>
    </section>

    <section class="proof-card__qed" aria-labelledby="proof-qed-label">
      <span class="proof-card__qed-mark" aria-hidden="true">
        <img src="/assets/images/uploads/proof-mark-light.svg" alt="" loading="lazy" decoding="async">
      </span>
      <div>
        <h3 id="proof-qed-label" class="proof-card__qed-label">Q.E.D.</h3>
        <p class="proof-card__qed-text">{{ proofCard.qed or proofCard.conclusion }}</p>
      </div>
    </section>

    {% if proofCard.sourceDocuments.length %}
      <section class="proof-card__section proof-card__section--documents" id="proof-documents" aria-labelledby="proof-documents-label">
        <h3 id="proof-documents-label" class="proof-card__label">Documents</h3>
        <ul class="proof-card__documents">
          {% for doc in proofCard.sourceDocuments %}
            {% set docRecord = doc.documentUrl | getSourceDocument(collections.sourceDocument) %}
            {% set docType = (docRecord.data.file_type if docRecord else "DOC") | upper %}
            {% set docTypeClass = "proof-card__document-badge proof-card__document-badge--pdf" %}
            {% if docType == "IMAGE" %}
              {% set docTypeClass = "proof-card__document-badge proof-card__document-badge--image" %}
            {% endif %}
            <li>
              <a href="{{ doc.documentUrl }}" class="proof-card__document-link" data-doc-url="{{ doc.documentUrl }}">
                <span class="{{ docTypeClass }}">{{ docType }}</span>
                <span class="proof-card__document-name">{{ docRecord.data.title if docRecord else doc.label }}</span>
              </a>
            </li>
          {% endfor %}
        </ul>
      </section>
    {% endif %}
  </article>
</section>
