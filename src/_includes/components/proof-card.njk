{% set proofMarkDaySrc = site.proofMarkDay ~ "?v=" ~ buildVersion %}
{% set proofMarkNightSrc = site.proofMarkNight ~ "?v=" ~ buildVersion %}
{% set proofMarkPrintSrc = site.proofMarkPrint ~ "?v=" ~ buildVersion %}
<section class="proof-card proof-card--inline" aria-labelledby="proof-card-issue-{{ proofCard.slug }}">
  <div class="proof-card__body">
    <header class="proof-card__strap">
      <div class="proof-card__identity">
        <img class="proof-mark proof-card__mark" src="{{ proofMarkPrintSrc }}" alt="" />
        <p class="proof-card__eyebrow">Proof</p>
      </div>
      <p class="proof-card__counts">{{ proofCard.axiomCount }} axioms · {{ proofCard.logicCount }} inferences</p>
    </header>

    <section class="proof-card__section proof-card__section--full proof-card__section--hero" aria-label="Issue under proof">
      <p class="proof-card__label">Issue</p>
      <div class="proof-card__section-body">
        <h2 id="proof-card-issue-{{ proofCard.slug }}" class="proof-card__issue">{{ proofCard.issue }}</h2>
      </div>
    </section>

    <div class="proof-card__details">
      <section class="proof-card__section proof-card__section--panel">
        <p class="proof-card__label">Axioms</p>
        <div class="proof-card__section-body">
          <ol class="proof-card__list" aria-label="Axioms">
            {% for axiom in proofCard.axioms %}
              <li class="proof-card__list-item">
                <span class="proof-card__marker">A{{ axiom.index }}</span>
                <div class="proof-card__item-copy">
                  <p class="proof-card__list-text">{{ axiom.premise }}</p>
                  <a class="proof-card__source-link" href="{{ axiom.sourceUrl }}">{{ axiom.sourceLabel }}</a>
                </div>
              </li>
            {% endfor %}
          </ol>
        </div>
      </section>

      <section class="proof-card__section proof-card__section--panel">
        <p class="proof-card__label">Inferences</p>
        <div class="proof-card__section-body">
          <ol class="proof-card__list" aria-label="Inferences">
            {% for entry in proofCard.logic %}
              <li class="proof-card__list-item">
                <span class="proof-card__marker">I{{ entry.index }}</span>
                <div class="proof-card__item-copy">
                  <p class="proof-card__list-text">{{ entry.step }}</p>
                </div>
              </li>
            {% endfor %}
          </ol>
        </div>
      </section>
    </div>

    <section class="proof-card__section proof-card__section--full proof-card__section--conclusion" aria-label="Conclusion">
      <p class="proof-card__label">Conclusion</p>
      <div class="proof-card__section-body proof-card__section-body--conclusion">
        <p class="proof-card__conclusion">
          <img class="proof-card__ghost-mark" data-proof-mark data-proof-mark-day="{{ proofMarkNightSrc }}" data-proof-mark-night="{{ proofMarkNightSrc }}" data-proof-mark-print="{{ proofMarkPrintSrc }}" src="{{ proofMarkNightSrc }}" alt="" aria-hidden="true" />
          <span class="proof-card__conclusion-text">{{ proofCard.conclusion }}</span>
        </p>
      </div>
    </section>

    <footer class="proof-card__footer">
      <p class="proof-card__footer-text">
        Share the full article from the reading tools, or share this proof card directly from here.
      </p>
      <div class="proof-card__links">
        <button
          class="proof-card__link"
          type="button"
          data-share-page
          data-share-title="{{ proofCard.articleTitle }} proof card"
          data-share-url="{{ proofCard.shareImagePath | absoluteUrl(site.url) }}"
          hidden
        >
          Share proof card
        </button>
        <a class="proof-card__link" href="{{ proofCard.shareImagePath }}">Open proof image</a>
      </div>
    </footer>
  </div>
</section>
